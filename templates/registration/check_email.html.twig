{% extends 'base.html.twig' %}

{% block title %}Potwierdź e-mail — Dzieła Zebrane{% endblock %}
{% block body_class %}d-flex flex-column{% endblock %}

{% block stylesheets %}
<style>
    .login-page { background: #FAF8F5; display: flex; align-items: center; justify-content: center; padding: 2rem 1rem; }
    .login-wrapper { width: 100%; max-width: 460px; text-align: center; }
    .login-card { background: #fff; border: 1px solid #e8e0d4; border-radius: 12px; padding: 2.5rem 2.25rem; }
    .login-card h1 { font-family: var(--font-heading) !important; font-size: 1.5rem; color: #722F37; margin: 1rem 0 .5rem; }
    .login-card p { color: #666; font-size: .95rem; }
    .mail-icon { width: 64px; height: 64px; border-radius: 50%; background: #f5ecd9; color: #722F37; display: inline-flex; align-items: center; justify-content: center; font-size: 1.8rem; }
    .login-card a { color: #722F37; font-weight: 600; text-decoration: none; }
</style>
{% endblock %}

{% block body %}
<div class="login-page">
    <div class="login-wrapper">
        <div class="login-card">
            <div class="mail-icon"><i class="ti ti-mail-check"></i></div>
            <h1>Sprawdź skrzynkę pocztową</h1>
            <p>Wysłaliśmy link aktywacyjny na podany adres e-mail.
               Kliknij go, aby potwierdzić rejestrację i móc się zalogować.</p>
            <p class="text-muted" style="font-size:.85rem;">Link jest ważny 24 godziny. Sprawdź też folder „Spam".</p>
            <hr>
            <a href="{{ path('app_login') }}">Przejdź do logowania</a>
        </div>
    </div>
</div>
{% endblock %}
