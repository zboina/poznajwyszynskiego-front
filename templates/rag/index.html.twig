            {# ── Panel: zakres przeszukiwania ── #}
            {% if volumes|length > 1 %}
            <div class="rag-pop" id="pop-scope" data-pop="scope">
                <div class="rag-pop-head">
                    <span class="ttl"><i class="ti ti-books"></i> Przeszukuj</span>
