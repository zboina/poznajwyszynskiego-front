{% extends 'base.html.twig' %}

{% block title %}Asystent AI — Dzieła Zebrane Kardynała Wyszyńskiego{% endblock %}

{% block stylesheets %}
{# Tabler core (loaded in base) nie zawiera fontu ikon — dociągamy go, bo ten widok używa klas `ti ti-*` #}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.31.0/dist/tabler-icons.min.css">
<style>
    :root { --pw-maroon: #722F37; --pw-maroon-dark: #5C2630; --pw-gold: #c8b78d; --pw-cream: #f8f4ec; }

    .rag-page { background: var(--pw-cream); }
    .rag-wrap { max-width: 860px; margin: 0 auto; padding: 2.5rem 1rem 12rem; }

    /* ═══════ Stan startowy: hero i pole pytania jako jeden blok, wyśrodkowany w pionie ═══════
       Przyklejone do dołu pustego ekranu ginęło — między hero a paskiem zieje pustka,
       więc wzrok nie ma czym zjechać. Centrujemy w WOLNEJ wysokości (to, co zostało po
       nawigacji i stopce), nie w całym oknie — dlatego blok siada wysoko, a stopka
       zostaje na ekranie. Po pierwszym pytaniu composer dokuje do dołu i zachowuje się
       jak w czacie: zawsze pod ostatnią odpowiedzią. */
    .rag-page.start { display: flex; flex-direction: column; justify-content: center; }
    .rag-page.start .rag-wrap { padding-top: 1rem; padding-bottom: .5rem; }
    .rag-page.start .rag-composer {
        position: static; background: none; padding: 0 1rem 1rem; pointer-events: auto; }
    /* Panele i tu otwierają się w górę — przykrywają hero, ale mają na to miejsce.
       W dół zostaje tylko dolna połowa ekranu minus podpowiedź, więc panel by się urywał. */
    .rag-page.start .rag-pop-body { max-height: min(40vh, 330px); }

    .rag-hero { text-align: center; margin-bottom: 2rem; }
    /* Po pierwszym pytaniu hero ustępuje miejsca wątkowi. */
    .rag-hero.collapsed { display: none; }
    .rag-hero .crest {
        width: 60px; height: 60px; border-radius: 50%; display: inline-flex;
        align-items: center; justify-content: center; margin-bottom: .75rem;
        background: var(--pw-maroon); color: #fff; font-size: 1.7rem;
        box-shadow: 0 6px 20px rgba(114,47,55,.35);
    }
    .rag-hero h1 { font-family: var(--font-heading); color: var(--pw-maroon);
        font-weight: 700; font-size: 2.3rem; margin: 0; }
    .rag-hero p { color: #6b6256; max-width: 560px; margin: .5rem auto 0; font-size: 1.02rem; }

    .rag-msg { margin-bottom: 1.5rem; }
    .rag-q {
        display: flex; gap: .75rem; align-items: flex-start; justify-content: flex-end;
        margin-bottom: .9rem;
    }
    .rag-q .bubble {
        background: var(--pw-maroon); color: #fff; padding: .7rem 1.1rem; border-radius: 16px 16px 4px 16px;
        font-weight: 500; max-width: 80%; box-shadow: 0 2px 10px rgba(114,47,55,.18);
    }
    .rag-a { display: flex; gap: .85rem; align-items: flex-start; }
    .rag-a .avatar {
        flex: 0 0 auto; width: 38px; height: 38px; border-radius: 50%; background: var(--pw-cream);
        border: 1px solid var(--pw-gold); color: var(--pw-maroon);
        display: flex; align-items: center; justify-content: center; font-size: 1.1rem; margin-top: 2px;
    }
    .rag-a .panel {
        flex: 1 1 auto; background: #fff; border: 1px solid #ece5d8; border-radius: 4px 16px 16px 16px;
        box-shadow: 0 4px 24px rgba(60,50,30,.07); padding: 1.25rem 1.4rem; min-width: 0;
    }

    .rag-status { color: #8a7d68; font-size: .92rem; display: flex; align-items: center; }

    .rag-answer { font-family: var(--font-body); line-height: 1.75; font-size: 1.05rem; color: #2b2620; }
    .rag-answer h1, .rag-answer h2, .rag-answer h3 { font-family: var(--font-heading);
        color: var(--pw-maroon); margin: 1.1rem 0 .5rem; font-size: 1.25rem; }
    .rag-answer p { margin: 0 0 .85rem; }
    .rag-answer ul, .rag-answer ol { margin: 0 0 .9rem; padding-left: 1.4rem; }
    .rag-answer li { margin-bottom: .35rem; }
    .rag-answer strong { color: #1c1813; }
    .rag-answer blockquote {
        border-left: 3px solid var(--pw-gold); margin: .6rem 0; padding: .15rem 0 .15rem 1rem;
        color: #5a5246; font-style: italic; }
    .rag-answer a.rag-cite {
        font-size: .72em; vertical-align: super; color: var(--pw-maroon); font-weight: 700;
        text-decoration: none; padding: 0 1px; }
    .rag-answer a.rag-cite:hover { text-decoration: underline; }

    .rag-sources { border-top: 1px solid #efe9dd; margin-top: 1.25rem; padding-top: .9rem; }
    .rag-sources .ttl { color: #8a7d68; font-size: .8rem; text-transform: uppercase;
        letter-spacing: .04em; margin-bottom: .55rem; }
    .rag-source { display: flex; gap: .55rem; padding: .3rem 0; font-size: .93rem; align-items: baseline; }
    .rag-source .num {
        flex: 0 0 auto; min-width: 1.5rem; height: 1.5rem; border-radius: 50%;
        background: var(--pw-cream); border: 1px solid var(--pw-gold); color: var(--pw-maroon);
        font-weight: 700; font-size: .78rem; display: inline-flex; align-items: center; justify-content: center; }
    .rag-source a { color: #2b2620; text-decoration: none; font-weight: 500; }
    .rag-source a:hover { color: var(--pw-maroon); text-decoration: underline; }
    .rag-source .lbl { color: #9a7b3c; white-space: nowrap; font-size: .86rem; }
    .rag-source .go { color: var(--pw-maroon); opacity: .5; font-size: .8rem; }
    .rag-source a:hover + .lbl + .go, .rag-source:hover .go { opacity: 1; }

    .rag-toolbar { margin-top: 1rem; display: flex; gap: .5rem; }
    .rag-toolbar .btn { font-size: .85rem; }

    /* ═══════ Pasek narzędzi w composerze („taca”) + jeden wspólny panel ═══════
       Przykłady, Zakres i Historia dzielą tę samą mechanikę: przycisk w tacy
       otwiera panel nad polem pytania. Jeden panel naraz — Esc i klik obok
       zamykają. Stąd spójność: trzy różne treści, jeden język wizualny. */
    .rag-shell { position: relative; }

    .rag-tray {
        display: flex; align-items: center; gap: .25rem;
        padding: .35rem .15rem 0; margin-top: .3rem; border-top: 1px solid #f2ebdd; }
    .rag-tray-btn {
        display: inline-flex; align-items: center; gap: .35rem; border: 0; background: transparent;
        color: #8a7d68; font-size: .82rem; font-weight: 600; cursor: pointer;
        padding: .32rem .6rem; border-radius: 999px; transition: background .14s, color .14s; }
    .rag-tray-btn:hover { background: var(--pw-cream); color: var(--pw-maroon); }
    .rag-tray-btn[aria-expanded="true"] { background: var(--pw-maroon); color: #fff; }
    .rag-tray-btn i { font-size: .95rem; }
    .rag-tray-btn .chev { font-size: .7rem; opacity: .7; transition: transform .18s; }
    .rag-tray-btn[aria-expanded="true"] .chev { transform: rotate(180deg); }
    /* Zawężony zakres widać bez otwierania panelu. */
    .rag-tray-btn.is-set { color: var(--pw-maroon); background: var(--pw-cream); box-shadow: inset 0 0 0 1px var(--pw-gold); }
    .rag-tray-btn.is-set[aria-expanded="true"] { color: #fff; background: var(--pw-maroon); box-shadow: none; }
    .rag-tray-spacer { flex: 1 1 auto; }
    .rag-tray-credits { color: #9a917f; font-size: .78rem; white-space: nowrap; padding-right: .4rem; }
    .rag-tray-credits strong { color: var(--pw-maroon); }
    .rag-tray-credits.low strong { color: #a34141; }

    .rag-pop {
        position: absolute; bottom: calc(100% + .55rem); left: 0; right: 0; display: none;
        background: #fff; border: 1px solid var(--pw-gold); border-radius: 16px; overflow: hidden;
        box-shadow: 0 16px 44px rgba(60,50,30,.20), 0 2px 8px rgba(60,50,30,.10); }
    .rag-pop.open { display: flex; flex-direction: column; animation: ragPopIn .16s ease-out; }
    @keyframes ragPopIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
    .rag-pop-head {
        display: flex; align-items: center; gap: .5rem; padding: .65rem 1rem;
        border-bottom: 1px solid #f2ebdd; background: var(--pw-cream); }
    .rag-pop-head .ttl {
        flex: 1 1 auto; display: flex; align-items: center; gap: .45rem;
        color: var(--pw-maroon); font-weight: 700; font-size: .9rem; }
    .rag-pop-x {
        border: 0; background: transparent; color: #8a7d68; cursor: pointer;
        width: 26px; height: 26px; border-radius: 7px;
        display: inline-flex; align-items: center; justify-content: center; }
    .rag-pop-x:hover { background: #eee4cf; color: var(--pw-maroon); }
    .rag-pop-body { overflow-y: auto; max-height: min(50vh, 400px); padding: .7rem 1rem .9rem; }
    .rag-pop-foot { border-top: 1px solid #f2ebdd; padding: .55rem 1rem; text-align: center; }
    .rag-pop-foot a { color: var(--pw-maroon); font-weight: 700; font-size: .85rem; text-decoration: none; }
    .rag-pop-foot a:hover { text-decoration: underline; }
    .rag-pop-empty { color: #9a917f; font-size: .9rem; text-align: center; padding:1.3rem .5rem; }

    /* Przykłady — kategorie w dwóch kolumnach, by lista mieściła się bez długiego scrolla. */
    .rag-ex-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0 1.5rem; }
    @media (max-width: 640px) { .rag-ex-grid { grid-template-columns: 1fr; } }
    .rag-ex-cat {
        font-size: .7rem; text-transform: uppercase; letter-spacing: .06em; font-weight: 700;
        color: #9a7b3c; margin: .55rem .3rem .2rem; }
    .rag-pick {
        display: block; width: 100%; text-align: left; cursor: pointer;
        background: transparent; border: 0; border-radius: 9px; padding: .42rem .55rem;
        color: #2b2620; font-size: .9rem; line-height: 1.35; transition: background .12s, color .12s; }
    .rag-pick:hover { background: var(--pw-cream); color: var(--pw-maroon); }

    /* Zakres — lista tomów; ptaszek pokazuje aktywny. */
    .rag-vol {
        display: flex; align-items: center; gap: .6rem; width: 100%; text-align: left;
        cursor: pointer; background: transparent; border: 0; border-radius: 9px;
        padding: .5rem .6rem; color: #2b2620; font-size: .92rem; }
    .rag-vol:hover { background: var(--pw-cream); }
    .rag-vol .tick { flex: 0 0 auto; width: 1.1rem; color: var(--pw-maroon); opacity: 0; }
    .rag-vol[aria-checked="true"] { color: var(--pw-maroon); font-weight: 700; }
    .rag-vol[aria-checked="true"] .tick { opacity: 1; }
    .rag-vol .vt { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    /* Historia — same pytania; przypięte na górze, oddzielone kreską. */
    .rag-hist {
        display: flex; align-items: baseline; gap: .55rem; width: 100%; text-align: left;
        cursor: pointer; background: transparent; border: 0; border-radius: 9px;
        padding: .45rem .55rem; color: #2b2620; font-size: .9rem; }
    .rag-hist:hover { background: var(--pw-cream); color: var(--pw-maroon); }
    .rag-hist .pin { flex: 0 0 auto; width: 1rem; color: var(--pw-gold); font-size: .85rem; }
    .rag-hist .qt { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .rag-hist .sc { flex: 0 0 auto; color: #9a917f; font-size: .75rem; }
    .rag-hist-sep { border-top: 1px dashed #ece2cc; margin: .45rem .25rem; }

    .rag-composer {
        position: fixed; left: 0; right: 0; bottom: 0; z-index: 20;
        /* Dłuższy, gęstszy zanik u dołu — tekst wątku „wtapia się" pod paskiem,
           a sam blok nie ginie, bo dolne 60% jest w pełni kryjące. */
        background: linear-gradient(to top, var(--pw-cream) 60%, rgba(248,244,236,.9) 80%, rgba(248,244,236,0) 100%);
        padding: 2rem 1rem 1.15rem;
        /* Strefa zaniku przepuszcza kliknięcia do wątku pod spodem; treść paska je odzyskuje. */
        pointer-events: none; }
    .rag-composer .inner { max-width: 860px; margin: 0 auto; pointer-events: auto; }
    .rag-composer .box {
        display: flex; flex-direction: column; background: #fff;
        border: 1.5px solid var(--pw-gold); border-radius: 18px; padding: .5rem .6rem .4rem;
        /* Warstwowy cień unosi blok nad stroną → nie zlewa się z tłem. */
        box-shadow: 0 12px 36px rgba(60,50,30,.16), 0 2px 8px rgba(60,50,30,.09);
        transition: border-color .18s, box-shadow .18s, transform .18s; }
    /* Wiersz z polem i przyciskiem wyślij; taca siedzi pod nim, w tej samej ramce. */
    .rag-composer .box-input { display: flex; gap: .5rem; align-items: flex-end; padding-left: .55rem; }
    /* Wyraźne podświetlenie w trakcie pisania — blok „ożywa" i przyciąga wzrok. */
    .rag-composer .box:focus-within {
        border-color: var(--pw-maroon);
        box-shadow: 0 14px 44px rgba(114,47,55,.22), 0 0 0 4px rgba(114,47,55,.10);
        transform: translateY(-1px); }
    .rag-composer textarea {
        flex: 1; border: 0; outline: 0; resize: none; font-size: 1.05rem; line-height: 1.5;
        max-height: 160px; background: transparent; font-family: var(--font-body); color: #2b2620;
        /* Pionowy padding zrównuje wysokość jednoliniowego pola z przyciskiem (46px),
           więc placeholder/tekst jest wyśrodkowany w pionie. box-sizing, by autosize
           (scrollHeight) uwzględniał padding i nie „rósł" przy każdym wpisaniu. */
        padding: .62rem 0; box-sizing: border-box; }
    .rag-composer textarea::placeholder { color: #a99f8c; }
    .rag-composer .send {
        flex: 0 0 auto; width: 46px; height: 46px; border-radius: 14px; border: 0;
        background: linear-gradient(135deg, var(--pw-maroon), var(--pw-maroon-dark));
        color: #fff; font-size: 1.2rem; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 12px rgba(114,47,55,.30);
        transition: transform .12s, box-shadow .15s, opacity .15s; }
    .rag-composer .send:hover:not(:disabled) {
        transform: translateY(-1px); box-shadow: 0 7px 18px rgba(114,47,55,.40); }
    .rag-composer .send:active:not(:disabled) { transform: translateY(0); box-shadow: 0 3px 9px rgba(114,47,55,.32); }
    .rag-composer .send:disabled { opacity: .4; cursor: default; box-shadow: none; }
    .rag-composer .send.stop { background: linear-gradient(135deg, #a34141, #8a3b3b); box-shadow: 0 4px 12px rgba(138,59,59,.34); }
    .rag-blocked {
        display: flex; align-items: center; justify-content: center; gap: .5rem; flex-wrap: wrap;
        background: #fff; border: 1px solid var(--pw-gold); border-radius: 16px;
        padding: .85rem 1.1rem; color: #8a3b3b; font-weight: 600; font-size: .92rem;
        box-shadow: 0 6px 28px rgba(60,50,30,.12); }
    .rag-blocked a { color: var(--pw-maroon); font-weight: 700; text-decoration: none; }
    .rag-blocked a:hover { text-decoration: underline; }
    .rag-badge { background: var(--pw-cream); border: 1px solid var(--pw-gold); color: #5a4a2e;
        border-radius: 999px; padding: .1rem .6rem; font-size: .75rem; font-weight: 600; }

    /* ── Source preview modal ── */
    .rag-modal { position: fixed; inset: 0; z-index: 1080; display: none; }
    .rag-modal.open { display: block; }
    .rag-modal-backdrop { position: absolute; inset: 0; background: rgba(28,24,19,.55); backdrop-filter: blur(2px); }
    .rag-modal-dialog {
        position: absolute; top: 4vh; left: 50%; transform: translateX(-50%);
        width: min(820px, 94vw); max-height: 92vh; display: flex; flex-direction: column;
        background: #fff; border-radius: 14px; overflow: hidden;
        box-shadow: 0 24px 70px rgba(20,15,10,.45); animation: ragModalIn .18s ease-out; }
    @keyframes ragModalIn { from { opacity: 0; transform: translate(-50%, 8px); } to { opacity: 1; transform: translate(-50%, 0); } }
    .rag-modal-head {
        display: flex; align-items: flex-start; gap: 1rem; padding: 1rem 1.25rem;
        background: linear-gradient(135deg, var(--pw-maroon), var(--pw-maroon-dark)); color: #fff; }
    .rag-modal-eyebrow { font-size: .7rem; text-transform: uppercase; letter-spacing: .08em; opacity: .75; }
    .rag-modal-title { font-family: var(--font-heading); font-size: 1.15rem; font-weight: 700; margin: .1rem 0 0; line-height: 1.25; }
    .rag-modal-ref { font-size: .82rem; opacity: .85; margin-top: .15rem; }
    .rag-modal-titles { flex: 1 1 auto; min-width: 0; }
    .rag-modal-actions { flex: 0 0 auto; display: flex; gap: .4rem; }
    .rag-modal-open, .rag-modal-x {
        width: 34px; height: 34px; border-radius: 9px; border: 0; cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center;
        background: rgba(255,255,255,.15); color: #fff; font-size: 1rem; text-decoration: none; transition: background .15s; }
    .rag-modal-open:hover, .rag-modal-x:hover { background: rgba(255,255,255,.3); color: #fff; }
    .rag-modal-body { overflow-y: auto; padding: 1.5rem 1.75rem; background: #fdfbf6; }
    .rag-modal-body.loading { text-align: center; color: #8a7d68; padding: 3rem; }

    {# Typografia treści dokumentu (.pw-doc) — partials/_document_text.html.twig #}
    /* W wąskim modalu kolumna tekstu bierze całą dostępną szerokość. */
    .rag-modal-dialog { --pwd-measure: none; }
    .rag-modal-body.pw-doc mark.rag-hl { scroll-margin-top: 1.5rem; }

    /* ── Tła tekstu z panelu ustawień czytania (data-bg na .rag-modal-dialog) ── */
    .rag-modal-dialog[data-bg="biel"] .rag-modal-body { background: #fff; color: #24201a; }
    .rag-modal-dialog[data-bg="sepia"] .rag-modal-body { background: #f4e9cf; color: #4a3a24; }
    .rag-modal-dialog[data-bg="noc"] .rag-modal-body { background: #241d16; color: #dccdb0; }
    .rag-modal-dialog[data-bg="noc"] .rag-modal-body .page-marker {
        color: #e6cd78; background: rgba(201,162,39,.12); border-color: rgba(201,162,39,.35); }
    .rag-modal-dialog[data-bg="noc"] .rag-modal-body .footnotes { color: #b3a17f; border-top-color: rgba(201,162,39,.3); }
</style>
{{ include('partials/_document_text.html.twig') }}
{% endblock %}

{% block body %}
{% include 'partials/_navbar.html.twig' %}
<div class="rag-page start" id="rag-page">
<div class="rag-wrap">
    <div class="rag-hero" id="rag-hero">
        <div class="crest"><i class="ti ti-feather"></i></div>
        <h1>Asystent Dzieł Zebranych</h1>
        <p>Zadaj pytanie — odpowiem wyłącznie na podstawie pism kardynała Stefana Wyszyńskiego,
           z odnośnikami do tomu i strony wydania drukowanego.</p>
        {% if volumes is empty %}
            <p class="mt-2"><span class="rag-badge">Korpus w przygotowaniu</span></p>
        {% endif %}
    </div>

    <div id="rag-thread"></div>
</div>

<div class="rag-composer" data-bottom-bar>
    <div class="inner">
        <div class="rag-shell" id="rag-shell">

            {# ── Panel: przykładowe pytania ── #}
            <div class="rag-pop" id="pop-examples" data-pop="examples">
                <div class="rag-pop-head">
                    <span class="ttl"><i class="ti ti-bulb"></i> Przykładowe pytania</span>
                    <button type="button" class="rag-pop-x" data-pop-close title="Zamknij"><i class="ti ti-x"></i></button>
                </div>
                <div class="rag-pop-body">
                    <div class="rag-ex-grid">
                        <div>
                            <div class="rag-ex-cat">Kościół i Sobór Watykański II</div>
                            <button type="button" class="rag-pick">Co Kardynał Wyszyński mówił o głównych nurtach Soboru Watykańskiego II?</button>
                            <button type="button" class="rag-pick">Jak Prymas rozumiał Kościół jako „Rodzinę Bożą"?</button>
                            <button type="button" class="rag-pick">Co mówił o odnowie liturgii i konstytucji o liturgii świętej?</button>
                            <button type="button" class="rag-pick">Jak odniósł się do encykliki „Pacem in terris" i sprawy pokoju?</button>
                        </div>
                        <div>
                            <div class="rag-ex-cat">Maryja i pobożność</div>
                            <button type="button" class="rag-pick">Czym było oddanie się w „słodką niewolę" Matki Najświętszej?</button>
                            <button type="button" class="rag-pick">Co Kardynał Wyszyński mówił o Maryi jako Matce Kościoła?</button>
                            <button type="button" class="rag-pick">Jakie znaczenie nadawał Apelowi Jasnogórskiemu?</button>
                            <button type="button" class="rag-pick">Co mówił o Tysiącleciu Chrztu Polski?</button>
                        </div>
                        <div>
                            <div class="rag-ex-cat">Rodzina, młodzież, powołanie</div>
                            <button type="button" class="rag-pick">Co Prymas mówił o rodzinie katolickiej?</button>
                            <button type="button" class="rag-pick">Jakie przesłanie kierował do młodzieży akademickiej?</button>
                            <button type="button" class="rag-pick">Co mówił dziewczętom o godności i powołaniu kobiety?</button>
                            <button type="button" class="rag-pick">Jak rozumiał powołanie i odpowiedzialność mężczyzn katolickich?</button>
                        </div>
                        <div>
                            <div class="rag-ex-cat">Kapłaństwo i naród</div>
                            <button type="button" class="rag-pick">Co Kardynał Wyszyński mówił do neoprezbiterów w dniu święceń?</button>
                            <button type="button" class="rag-pick">Jakie zadania stawiał duchowieństwu polskiemu wobec potrzeb współczesnych?</button>
