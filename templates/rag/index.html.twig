{% extends 'base.html.twig' %}

{% block title %}Asystent AI — Dzieła Zebrane Kardynała Wyszyńskiego{% endblock %}

{% block stylesheets %}
{# Tabler core (loaded in base) nie zawiera fontu ikon — dociągamy go, bo ten widok używa klas `ti ti-*` #}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.31.0/dist/tabler-icons.min.css">
<style>
    :root { --pw-maroon: #722F37; --pw-maroon-dark: #5C2630; --pw-gold: #c8b78d; --pw-cream: #f8f4ec; }

    /* ═══════ Motywy v1–v6 — klasa layout-* jest na <body> (skrypt w _navbar).
       Cała strona używa var(--pw-maroon), więc zmiana tokenu przeskinowuje
       hero, dymki, przycisk wyślij, źródła, composer i modal. ═══════ */
    body.layout-v3, body.layout-v4 { --pw-maroon: #1A365D; --pw-maroon-dark: #12243f; }
    body.layout-v5 { --pw-maroon: #5C2630; --pw-maroon-dark: #481d26; }

    .rag-page { background:
        radial-gradient(1200px 400px at 50% -120px, #faf6ee 0%, transparent 70%); min-height: 100vh; }
    /* Tło dopasowane do temperatury motywu. */
    body.layout-v2 .rag-page { background: #fff; }
    body.layout-v3 .rag-page, body.layout-v4 .rag-page {
        background: radial-gradient(1200px 400px at 50% -120px, #eaf0f8 0%, transparent 70%); }
    body.layout-v5 .rag-page { background: radial-gradient(1200px 400px at 50% -120px, #f7eef0 0%, transparent 70%); }
    body.layout-v6 .rag-page { background: var(--pw-cream); }
    .rag-wrap { max-width: 860px; margin: 0 auto; padding: 2.5rem 1rem 11rem; }

    .rag-hero { text-align: center; margin-bottom: 2rem; }
    .rag-hero .crest {
        width: 60px; height: 60px; border-radius: 50%; display: inline-flex;
        align-items: center; justify-content: center; margin-bottom: .75rem;
        background: var(--pw-maroon); color: #fff; font-size: 1.7rem;
        box-shadow: 0 6px 20px rgba(114,47,55,.35);
    }
    .rag-hero h1 { font-family: var(--font-heading); color: var(--pw-maroon);
        font-weight: 700; font-size: 2.3rem; margin: 0; }
    .rag-hero p { color: #6b6256; max-width: 560px; margin: .5rem auto 0; font-size: 1.02rem; }

    .rag-histbar {
        display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; margin-bottom: 1.25rem; padding: .5rem .9rem;
        background: #fff; border: 1px solid #ece5d8; border-radius: 12px;
        box-shadow: 0 2px 12px rgba(60,50,30,.05); }
    .rag-histbar-label { color: #8a7d68; font-size: .85rem; font-weight: 600; }
    .rag-histbar-clear {
        border: 1px solid #e3d9c4; background: #fff; color: #8a3b3b;
        border-radius: 999px; padding: .25rem .75rem; font-size: .8rem; cursor: pointer;
        display: inline-flex; align-items: center; gap: .3rem; transition: all .15s; }
    .rag-histbar-clear:hover { background: #8a3b3b; color: #fff; border-color: #8a3b3b; }

    .rag-msg { margin-bottom: 1.5rem; }
    .rag-q {
        display: flex; gap: .75rem; align-items: flex-start; justify-content: flex-end;
        margin-bottom: .9rem;
    }
    .rag-q .bubble {
        background: var(--pw-maroon); color: #fff; padding: .7rem 1.1rem; border-radius: 16px 16px 4px 16px;
        font-weight: 500; max-width: 80%; box-shadow: 0 2px 10px rgba(114,47,55,.18);
    }
    .rag-a { display: flex; gap: .85rem; align-items: flex-start; }
    .rag-a .avatar {
        flex: 0 0 auto; width: 38px; height: 38px; border-radius: 50%; background: var(--pw-cream);
        border: 1px solid var(--pw-gold); color: var(--pw-maroon);
        display: flex; align-items: center; justify-content: center; font-size: 1.1rem; margin-top: 2px;
    }
    .rag-a .panel {
        flex: 1 1 auto; background: #fff; border: 1px solid #ece5d8; border-radius: 4px 16px 16px 16px;
        box-shadow: 0 4px 24px rgba(60,50,30,.07); padding: 1.25rem 1.4rem; min-width: 0;
    }

    .rag-status { color: #8a7d68; font-size: .92rem; display: flex; align-items: center; }

    .rag-answer { font-family: var(--font-body); line-height: 1.75; font-size: 1.05rem; color: #2b2620; }
    .rag-answer h1, .rag-answer h2, .rag-answer h3 { font-family: var(--font-heading);
        color: var(--pw-maroon); margin: 1.1rem 0 .5rem; font-size: 1.25rem; }
    .rag-answer p { margin: 0 0 .85rem; }
    .rag-answer ul, .rag-answer ol { margin: 0 0 .9rem; padding-left: 1.4rem; }
    .rag-answer li { margin-bottom: .35rem; }
    .rag-answer strong { color: #1c1813; }
    .rag-answer blockquote {
        border-left: 3px solid var(--pw-gold); margin: .6rem 0; padding: .15rem 0 .15rem 1rem;
        color: #5a5246; font-style: italic; }
    .rag-answer a.rag-cite {
        font-size: .72em; vertical-align: super; color: var(--pw-maroon); font-weight: 700;
        text-decoration: none; padding: 0 1px; }
    .rag-answer a.rag-cite:hover { text-decoration: underline; }

    .rag-sources { border-top: 1px solid #efe9dd; margin-top: 1.25rem; padding-top: .9rem; }
    .rag-sources .ttl { color: #8a7d68; font-size: .8rem; text-transform: uppercase;
        letter-spacing: .04em; margin-bottom: .55rem; }
    .rag-source { display: flex; gap: .55rem; padding: .3rem 0; font-size: .93rem; align-items: baseline; }
    .rag-source .num {
        flex: 0 0 auto; min-width: 1.5rem; height: 1.5rem; border-radius: 50%;
        background: var(--pw-cream); border: 1px solid var(--pw-gold); color: var(--pw-maroon);
        font-weight: 700; font-size: .78rem; display: inline-flex; align-items: center; justify-content: center; }
    .rag-source a { color: #2b2620; text-decoration: none; font-weight: 500; }
    .rag-source a:hover { color: var(--pw-maroon); text-decoration: underline; }
    .rag-source .lbl { color: #9a7b3c; white-space: nowrap; font-size: .86rem; }
    .rag-source .go { color: var(--pw-maroon); opacity: .5; font-size: .8rem; }
    .rag-source a:hover + .lbl + .go, .rag-source:hover .go { opacity: 1; }

    .rag-toolbar { margin-top: 1rem; display: flex; gap: .5rem; }
    .rag-toolbar .btn { font-size: .85rem; }

    /* ── Rozwijana lista przykładowych pytań ── */
    .rag-examples { max-width: 720px; margin: 0 auto; }
    .rag-ex-toggle {
        width: 100%; display: flex; align-items: center; gap: .55rem;
        background: #fff; border: 1px solid var(--pw-gold); border-radius: 14px;
        padding: .8rem 1.1rem; color: var(--pw-maroon); font-weight: 700; font-size: .95rem;
        cursor: pointer; box-shadow: 0 2px 14px rgba(60,50,30,.05); transition: background .15s; }
    .rag-ex-toggle:hover { background: var(--pw-cream); }
    .rag-ex-toggle span { flex: 1 1 auto; text-align: left; }
    .rag-ex-toggle .ti-chevron-down { transition: transform .2s; }
    .rag-ex-toggle[aria-expanded="true"] .ti-chevron-down { transform: rotate(180deg); }
    .rag-ex-panel { display: none; margin-top: .6rem; }
    .rag-ex-panel.open { display: block; animation: ragExIn .18s ease-out; }
    @keyframes ragExIn { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: none; } }
    .rag-ex-group { margin-bottom: 1rem; }
    .rag-ex-cat {
        font-size: .72rem; text-transform: uppercase; letter-spacing: .06em; font-weight: 700;
        color: #9a7b3c; margin: 0 .15rem .4rem; }
    .rag-ex-q {
        display: block; width: 100%; text-align: left; cursor: pointer;
        background: #fff; border: 1px solid #ece5d8; border-radius: 10px;
        padding: .6rem .85rem; margin-bottom: .4rem; color: #2b2620; font-size: .92rem;
        line-height: 1.4; transition: all .12s; }
    .rag-ex-q:hover { border-color: var(--pw-gold); background: var(--pw-cream); color: var(--pw-maroon); transform: translateX(2px); }

    .rag-composer {
        position: fixed; left: 0; right: 0; bottom: 0; z-index: 20;
        background: linear-gradient(to top, #fff 70%, rgba(255,255,255,0));
        padding: 1.5rem 1rem 1.1rem; }
    .rag-composer .inner { max-width: 860px; margin: 0 auto; }
    .rag-composer .box {
        display: flex; gap: .5rem; align-items: flex-end; background: #fff;
        border: 1px solid var(--pw-gold); border-radius: 16px; padding: .5rem .5rem .5rem 1rem;
        box-shadow: 0 6px 28px rgba(60,50,30,.12); }
    .rag-composer textarea {
        flex: 1; border: 0; outline: 0; resize: none; font-size: 1.02rem; line-height: 1.5;
        max-height: 160px; background: transparent; font-family: var(--font-body); }
    .rag-composer .send {
        flex: 0 0 auto; width: 42px; height: 42px; border-radius: 12px; border: 0;
        background: var(--pw-maroon); color: #fff; font-size: 1.1rem; cursor: pointer;
        display: flex; align-items: center; justify-content: center; transition: opacity .15s; }
    .rag-composer .send:disabled { opacity: .45; cursor: default; }
    .rag-composer .send.stop { background: #8a3b3b; }
    .rag-scope {
        display: flex; align-items: center; gap: .4rem; margin: 0 auto .55rem;
        width: fit-content; color: #8a7d68; font-size: .82rem; background: #fff;
        border: 1px solid var(--pw-gold); border-radius: 999px; padding: .25rem .75rem;
        box-shadow: 0 2px 10px rgba(60,50,30,.06); }
    .rag-scope select {
        border: 0; outline: 0; background: transparent; color: var(--pw-maroon);
        font-weight: 600; font-size: .82rem; cursor: pointer; padding-right: .2rem; }
    .rag-composer .hint { text-align: center; color: #9a917f; font-size: .78rem; margin-top: .5rem; }
    .rag-blocked {
        display: flex; align-items: center; justify-content: center; gap: .5rem; flex-wrap: wrap;
        background: #fff; border: 1px solid var(--pw-gold); border-radius: 16px;
        padding: .85rem 1.1rem; color: #8a3b3b; font-weight: 600; font-size: .92rem;
        box-shadow: 0 6px 28px rgba(60,50,30,.12); }
    .rag-blocked a { color: var(--pw-maroon); font-weight: 700; text-decoration: none; }
    .rag-blocked a:hover { text-decoration: underline; }
    .rag-badge { background: var(--pw-cream); border: 1px solid var(--pw-gold); color: #5a4a2e;
        border-radius: 999px; padding: .1rem .6rem; font-size: .75rem; font-weight: 600; }

    /* ── Archive (saved questions) quick list ── */
    .rag-histbar { flex-wrap: wrap; }
    .rag-histbar-toggle {
        border: 0; background: transparent; color: var(--pw-maroon); font-weight: 600;
        font-size: .85rem; cursor: pointer; display: inline-flex; align-items: center; gap: .35rem; }
    .rag-histlist { width: 100%; margin-top: .5rem; border-top: 1px dashed #e6ddca; padding-top: .5rem; display: none; }
    .rag-histlist.open { display: block; }
    .rag-histitem {
        display: flex; gap: .5rem; align-items: baseline; width: 100%; text-align: left;
        border: 0; background: transparent; cursor: pointer; padding: .3rem .25rem;
        border-radius: 6px; font-size: .9rem; color: #2b2620; }
    .rag-histitem:hover { background: var(--pw-cream); }
    .rag-histitem .qn { color: var(--pw-gold); font-weight: 700; flex: 0 0 auto; }
    .rag-histitem .qt { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    /* ── Source preview modal ── */
    .rag-modal { position: fixed; inset: 0; z-index: 1080; display: none; }
    .rag-modal.open { display: block; }
    .rag-modal-backdrop { position: absolute; inset: 0; background: rgba(28,24,19,.55); backdrop-filter: blur(2px); }
    .rag-modal-dialog {
        position: absolute; top: 4vh; left: 50%; transform: translateX(-50%);
        width: min(820px, 94vw); max-height: 92vh; display: flex; flex-direction: column;
        background: #fff; border-radius: 14px; overflow: hidden;
        box-shadow: 0 24px 70px rgba(20,15,10,.45); animation: ragModalIn .18s ease-out; }
    @keyframes ragModalIn { from { opacity: 0; transform: translate(-50%, 8px); } to { opacity: 1; transform: translate(-50%, 0); } }
    .rag-modal-head {
        display: flex; align-items: flex-start; gap: 1rem; padding: 1rem 1.25rem;
        background: linear-gradient(135deg, var(--pw-maroon), var(--pw-maroon-dark)); color: #fff; }
    .rag-modal-eyebrow { font-size: .7rem; text-transform: uppercase; letter-spacing: .08em; opacity: .75; }
    .rag-modal-title { font-family: var(--font-heading); font-size: 1.15rem; font-weight: 700; margin: .1rem 0 0; line-height: 1.25; }
    .rag-modal-ref { font-size: .82rem; opacity: .85; margin-top: .15rem; }
    .rag-modal-titles { flex: 1 1 auto; min-width: 0; }
    .rag-modal-actions { flex: 0 0 auto; display: flex; gap: .4rem; }
    .rag-modal-open, .rag-modal-x {
        width: 34px; height: 34px; border-radius: 9px; border: 0; cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center;
        background: rgba(255,255,255,.15); color: #fff; font-size: 1rem; text-decoration: none; transition: background .15s; }
    .rag-modal-open:hover, .rag-modal-x:hover { background: rgba(255,255,255,.3); color: #fff; }
    .rag-modal-body { overflow-y: auto; padding: 1.5rem 1.75rem; background: #fdfbf6; }
    .rag-modal-body.loading { text-align: center; color: #8a7d68; padding: 3rem; }

    /* doc content inside the modal */
    .rag-modal-body.doc-body { font-size: 1.02rem; line-height: 1.85; color: #2b2620; }
    .rag-modal-body p { margin: 0 0 1em; }
    .rag-modal-body .page-marker {
        display: inline-block; font-size: .76rem; font-weight: 600; color: var(--pw-maroon);
        background: #f5ecd9; border: 1px solid #c8b78d; border-radius: 3px; padding: 0 .35em;
        margin: 0 .25em; white-space: nowrap; vertical-align: baseline; line-height: 1.2; }
    .rag-modal-body mark.rag-hl {
        background: linear-gradient(180deg, #fff6c2 0%, #ffe98a 100%); color: inherit;
        padding: .08em .05em; border-radius: 2px; box-shadow: 0 0 0 1px rgba(200,167,39,.45);
        scroll-margin-top: 1.5rem; animation: ragHlPulse 2.4s ease-out 1; }
    @keyframes ragHlPulse {
        0% { box-shadow: 0 0 0 6px rgba(200,167,39,.45); }
        60% { box-shadow: 0 0 0 6px rgba(200,167,39,.18); }
        100% { box-shadow: 0 0 0 1px rgba(200,167,39,.45); } }
    .rag-modal-body .footnotes { margin-top: 2em; padding-top: 1em; border-top: 1px solid #e6ddca; font-size: .85rem; color: #6b6256; }
</style>
{% endblock %}

{% block body %}
{% include 'partials/_navbar.html.twig' %}
<div class="rag-page">
<div class="rag-wrap">
    <div class="rag-hero">
        <div class="crest"><i class="ti ti-feather"></i></div>
        <h1>Asystent Dzieł Zebranych</h1>
        <p>Zadaj pytanie — odpowiem wyłącznie na podstawie pism kardynała Stefana Wyszyńskiego,
           z odnośnikami do tomu i strony wydania drukowanego.</p>
        <p class="mt-2">
            {% if volumes is empty %}
                <span class="rag-badge">Korpus w przygotowaniu</span>
            {% else %}
                <span class="rag-badge">Dostępne tomy:
                    {%- for v in volumes %} {{ v.roman }}{% if not loop.last %},{% endif %}{% endfor -%}
                </span>
            {% endif %}
            {% if not unlimited %}
                <span class="rag-badge" id="rag-credits" title="Pula pytań do asystenta">
                    Pozostało pytań: <strong id="rag-credits-n">{{ credits }}</strong>
                </span>
            {% endif %}
        </p>
        {% if not unlimited and credits <= 0 %}
            <p class="mt-1"><a href="{{ path('app_donate') }}" style="color:var(--pw-maroon);font-weight:700;">Doładuj pulę pytań — Wesprzyj →</a></p>
        {% endif %}
    </div>

    <div class="rag-histbar" id="rag-histbar" style="display:none;">
        <button type="button" class="rag-histbar-toggle" id="rag-histtoggle" aria-expanded="false">
            <i class="ti ti-history"></i> <span id="rag-histcount"></span>
            <i class="ti ti-chevron-down" id="rag-histchevron"></i>
        </button>
        <button type="button" id="rag-histclear" class="rag-histbar-clear">
            <i class="ti ti-trash"></i> Wyczyść historię
        </button>
        <div class="rag-histlist" id="rag-histlist"></div>
    </div>

    <div id="rag-thread"></div>

    <div class="rag-examples" id="rag-examples">
        <button type="button" class="rag-ex-toggle" id="rag-ex-toggle" aria-expanded="false">
            <i class="ti ti-bulb"></i>
            <span>Przykładowe pytania do asystenta</span>
            <i class="ti ti-chevron-down" id="rag-ex-chevron"></i>
        </button>
        <div class="rag-ex-panel" id="rag-ex-panel">
            <div class="rag-ex-group">
                <div class="rag-ex-cat">Kościół i Sobór Watykański II</div>
                <button class="rag-ex-q">Co Kardynał Wyszyński mówił o głównych nurtach Soboru Watykańskiego II?</button>
                <button class="rag-ex-q">Jak Prymas rozumiał Kościół jako „Rodzinę Bożą"?</button>
                <button class="rag-ex-q">Co mówił o odnowie liturgii i konstytucji o liturgii świętej?</button>
                <button class="rag-ex-q">Jak odniósł się do encykliki „Pacem in terris" i sprawy pokoju?</button>
            </div>
            <div class="rag-ex-group">
                <div class="rag-ex-cat">Maryja i pobożność</div>
                <button class="rag-ex-q">Czym było oddanie się w „słodką niewolę" Matki Najświętszej?</button>
                <button class="rag-ex-q">Co Kardynał Wyszyński mówił o Maryi jako Matce Kościoła?</button>
                <button class="rag-ex-q">Jakie znaczenie nadawał Apelowi Jasnogórskiemu?</button>
                <button class="rag-ex-q">Co mówił o Tysiącleciu Chrztu Polski?</button>
            </div>
            <div class="rag-ex-group">
                <div class="rag-ex-cat">Rodzina, młodzież, powołanie</div>
                <button class="rag-ex-q">Co Prymas mówił o rodzinie katolickiej?</button>
                <button class="rag-ex-q">Jakie przesłanie kierował do młodzieży akademickiej?</button>
                <button class="rag-ex-q">Co mówił dziewczętom o godności i powołaniu kobiety?</button>
                <button class="rag-ex-q">Jak rozumiał powołanie i odpowiedzialność mężczyzn katolickich?</button>
            </div>
            <div class="rag-ex-group">
                <div class="rag-ex-cat">Kapłaństwo i naród</div>
                <button class="rag-ex-q">Co Kardynał Wyszyński mówił do neoprezbiterów w dniu święceń?</button>
                <button class="rag-ex-q">Jakie zadania stawiał duchowieństwu polskiemu wobec potrzeb współczesnych?</button>
                <button class="rag-ex-q">Co mówił o miłości Ojczyzny i wolności narodu?</button>
                <button class="rag-ex-q">Jak ujmował chrześcijański sens pracy?</button>
            </div>
            <div class="rag-ex-group">
                <div class="rag-ex-cat">Życie i posługa Prymasa</div>
                <button class="rag-ex-q">Co Kardynał Wyszyński napisał po nominacji na arcybiskupa Gniezna i Warszawy?</button>
                <button class="rag-ex-q">Jak mówił o odbudowie katedry gnieźnieńskiej?</button>
                <button class="rag-ex-q">Co przekazał w odezwie na 950-lecie kanonizacji świętego Wojciecha?</button>
                <button class="rag-ex-q">Jakie słowa skierował do Polaków za granicą?</button>
            </div>
        </div>
    </div>
</div>

<div class="rag-composer">
    <div class="inner">
        {% if volumes|length > 1 %}
        <div class="rag-scope">
            <i class="ti ti-books"></i>
            <span>Zakres:</span>
            <select id="rag-scope">
                <option value="">Wszystkie tomy</option>
                {% for v in volumes %}
                    <option value="{{ v.number }}">Tom {{ v.roman }}</option>
                {% endfor %}
            </select>
        </div>
        {% endif %}
        <div class="box" id="rag-box">
            <textarea id="rag-q" rows="1" placeholder="Napisz pytanie do tekstów Prymasa…"></textarea>
            <button id="rag-send" class="send" title="Wyślij"><i class="ti ti-send"></i></button>
            <button id="rag-stop" class="send stop" title="Zatrzymaj" style="display:none;"><i class="ti ti-player-stop-filled"></i></button>
        </div>
        <div class="rag-blocked" id="rag-blocked" style="display:none;">
            <i class="ti ti-lock"></i>
            <span>Wykorzystałeś pulę pytań do asystenta.</span>
            <a href="{{ path('app_donate') }}">Doładuj — Wesprzyj →</a>
        </div>
        <div class="hint">Odpowiedzi generowane przez AI na podstawie korpusu — zweryfikuj z oryginałem przed cytowaniem.</div>
    </div>
</div>

{# ===== Source preview modal ===== #}
<div class="rag-modal" id="rag-modal" aria-hidden="true">
    <div class="rag-modal-backdrop" data-rag-modal-close></div>
    <div class="rag-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="rag-modal-title">
        <div class="rag-modal-head">
            <div class="rag-modal-titles">
                <div class="rag-modal-eyebrow">Źródło</div>
                <h2 class="rag-modal-title" id="rag-modal-title"></h2>
                <div class="rag-modal-ref" id="rag-modal-ref"></div>
            </div>
            <div class="rag-modal-actions">
                <a class="rag-modal-open" id="rag-modal-open" href="#" target="_blank" rel="noopener" title="Otwórz pełny tekst w nowej karcie">
                    <i class="ti ti-external-link"></i>
                </a>
                <button type="button" class="rag-modal-x" data-rag-modal-close title="Zamknij (Esc)">
                    <i class="ti ti-x"></i>
                </button>
            </div>
        </div>
        <div class="rag-modal-body doc-body" id="rag-modal-body"></div>
    </div>
</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/marked@12/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3/dist/purify.min.js"></script>
<script>
(function() {
    const thread = document.getElementById('rag-thread');
    const q = document.getElementById('rag-q');
    const send = document.getElementById('rag-send');
    const stop = document.getElementById('rag-stop');
    const scope = document.getElementById('rag-scope');
    const examples = document.getElementById('rag-examples');
    const box = document.getElementById('rag-box');
    const blocked = document.getElementById('rag-blocked');
    let seq = 0;
    let activeES = null;   // EventSource currently streaming, if any
    const unlimited = {{ unlimited ? 'true' : 'false' }};
    let credits = {{ credits|default(0) }};

    // Whether the user may currently ask a question.
    function canAsk() { return unlimited || credits > 0; }

    // Lock/unlock the composer based on the remaining question pool.
    function renderAskability() {
        const n = document.getElementById('rag-credits-n');
        if (n) n.textContent = credits;
        if (canAsk()) {
            if (box) box.style.display = '';
            if (blocked) blocked.style.display = 'none';
            q.disabled = false;
        } else {
            if (box) box.style.display = 'none';
            if (blocked) blocked.style.display = '';
            q.disabled = true;
        }
    }

    // Server decrements a credit when a real answer is generated (citations returned).
    function spendCredit() {
        if (unlimited) return;
        credits = Math.max(0, credits - 1);
        renderAskability();
    }

    // Auto-follow the stream only when the reader is already near the bottom,
    // so we never yank the page while they're reading earlier text.
    function followIfAtBottom() {
        const nearBottom = window.innerHeight + window.scrollY >= document.body.scrollHeight - 160;
        if (nearBottom) window.scrollTo({ top: document.body.scrollHeight, behavior: 'auto' });
    }

    function setBusy(on) {
        send.style.display = on ? 'none' : '';
        stop.style.display = on ? '' : 'none';
        send.disabled = on;
    }

    const esc = (s) => s.replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));

    if (window.marked) marked.setOptions({ breaks: true, gfm: true });

    function sourceLink(c) {
        let href = '/tekst/' + c.document_id;
        if (c.chunk_id) href += '?frag=' + c.chunk_id;
        if (c.page_start) href += '#strona-' + c.page_start;
        return href;
    }

    function renderAnswer(rawMd, citations, blockId) {
        // 1) Markdown → HTML (sanitised). 2) turn [n] into superscript links to the source list.
        let html = window.marked ? marked.parse(rawMd) : esc(rawMd).replace(/\n/g, '<br>');
        if (window.DOMPurify) html = DOMPurify.sanitize(html);
        html = html.replace(/\[(\d+)\]/g, (m, n) =>
            `<a href="#${blockId}-src-${n}" class="rag-cite">[${n}]</a>`);
        return html;
    }

    function isNoAnswer(t) {
        return /nie ma odpowiedzi|nie zawieraj|brak (informacji|odpowiedzi)/i.test(t);
    }

    // Show only the sources the answer actually cites ([n]). No citation → no
    // sources (e.g. "brak odpowiedzi"). Answered but uncited → show all.
    function finalSources(answer, citations) {
        if (!answer.trim() || isNoAnswer(answer)) return [];
        const used = new Set();
        (answer.match(/\[(\d+)\]/g) || []).forEach(m => used.add(parseInt(m.replace(/\D/g, ''), 10)));
        if (used.size) return citations.filter(c => used.has(c.n));
        return citations;
    }

    function sourcesHtml(citations, blockId) {
        if (!citations || !citations.length) return '';
        let s = '<div class="rag-sources"><div class="ttl">Źródła</div>';
        for (const c of citations) {
            const attrs = `data-doc="${c.document_id}" data-frag="${c.chunk_id || ''}" `
                + `data-page="${c.page_start || ''}" data-title="${esc(c.title)}" data-label="${esc(c.label)}"`;
            s += `<div class="rag-source" id="${blockId}-src-${c.n}">
                <span class="num">${c.n}</span>
                <span><a href="${sourceLink(c)}" class="rag-srclink" ${attrs}>${esc(c.title)}</a></span>
                <span class="lbl">— ${esc(c.label)}</span>
                <span class="go"><i class="ti ti-eye"></i></span>
            </div>`;
        }
        return s + '</div>';
    }

    // ── Source preview modal ──
    const modal = document.getElementById('rag-modal');
    const modalBody = document.getElementById('rag-modal-body');
    const modalTitle = document.getElementById('rag-modal-title');
    const modalRef = document.getElementById('rag-modal-ref');
    const modalOpen = document.getElementById('rag-modal-open');
    let modalAbort = null;

    function openModal(data) {
        modalTitle.textContent = data.title || 'Dokument';
        modalRef.textContent = data.label || '';
        modalOpen.href = data.href;
        modalBody.className = 'rag-modal-body doc-body loading';
        modalBody.innerHTML = '<div class="spinner-border" role="status" style="color:var(--pw-maroon);"></div>'
            + '<div class="mt-2">Wczytuję fragment…</div>';
        modal.classList.add('open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';

        let url = '/dokument/' + encodeURIComponent(data.doc) + '/tresc';
        if (data.frag) url += '?frag=' + encodeURIComponent(data.frag);

        if (modalAbort) modalAbort.abort();
        modalAbort = new AbortController();
        fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' }, signal: modalAbort.signal })
            .then(r => r.ok ? r.text() : Promise.reject(new Error(r.status === 403 ? 'limit' : 'err')))
            .then(html => {
                modalBody.className = 'rag-modal-body doc-body';
                modalBody.innerHTML = html;
                const mark = modalBody.querySelector('mark.rag-hl')
                    || (data.page ? modalBody.querySelector('#strona-' + data.page) : null);
                if (mark) requestAnimationFrame(() => mark.scrollIntoView({ behavior: 'smooth', block: 'center' }));
            })
            .catch(err => {
                if (err.name === 'AbortError') return;
                modalBody.className = 'rag-modal-body doc-body loading';
                modalBody.innerHTML = err.message === 'limit'
                    ? '<p class="text-danger">Wyczerpano dzienny limit podglądów dokumentów.</p>'
                    : '<p class="text-danger">Nie udało się wczytać treści źródła.</p>';
            });
    }

    function closeModal() {
        if (modalAbort) modalAbort.abort();
        modal.classList.remove('open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
    }

    modal.querySelectorAll('[data-rag-modal-close]').forEach(el => el.addEventListener('click', closeModal));
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && modal.classList.contains('open')) closeModal(); });

    // Clicking a source opens the modal; Ctrl/Cmd/middle-click keeps the new-tab behaviour.
    thread.addEventListener('click', e => {
        const link = e.target.closest('.rag-srclink');
        if (!link) return;
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.button === 1) return;
        e.preventDefault();
        openModal({
            doc: link.dataset.doc,
            frag: link.dataset.frag,
            page: link.dataset.page,
            title: link.dataset.title,
            label: link.dataset.label,
            href: link.getAttribute('href'),
        });
    });

    // Build one Q/A block. `withSpinner` shows the "searching…" status while streaming.
    function createMsg(question, withSpinner) {
        const blockId = 'b' + (++seq);
        const msg = document.createElement('div');
        msg.className = 'rag-msg';
        msg.innerHTML = `
            <div class="rag-q"><div class="bubble">${esc(question)}</div></div>
            <div class="rag-a">
                <div class="avatar"><i class="ti ti-feather"></i></div>
                <div class="panel">
                    <div class="rag-status"${withSpinner ? '' : ' style="display:none;"'}>
                        <span class="spinner-border spinner-border-sm me-2" style="color:var(--pw-maroon);"></span>
                        Przeszukuję źródła…
                    </div>
                    <div class="rag-answer"></div>
                    <div class="rag-srcbox"></div>
                    <div class="rag-toolbar" style="display:none;">
                        <button class="btn btn-sm btn-outline-secondary rag-copy">
                            <i class="ti ti-copy me-1"></i> Kopiuj
                        </button>
                        <button class="btn btn-sm btn-outline-secondary rag-docx">
                            <i class="ti ti-file-type-docx me-1"></i> Zapisz do DOCX
                        </button>
                    </div>
                </div>
            </div>`;
        thread.appendChild(msg);
        return {
            msg, blockId,
            statusEl: msg.querySelector('.rag-status'),
            answerEl: msg.querySelector('.rag-answer'),
            srcEl: msg.querySelector('.rag-srcbox'),
            toolbar: msg.querySelector('.rag-toolbar'),
            copyBtn: msg.querySelector('.rag-copy'),
            docxBtn: msg.querySelector('.rag-docx'),
        };
    }

    // Render a completed exchange (final answer + sources + action buttons).
    function finalize(refs, question, answerMd, shown) {
        refs.statusEl.style.display = 'none';
        refs.srcEl.innerHTML = sourcesHtml(shown, refs.blockId);
        refs.answerEl.innerHTML = renderAnswer(answerMd, shown, refs.blockId);
        if (shown.length || (answerMd.trim() && !isNoAnswer(answerMd))) {
            refs.toolbar.style.display = '';
            refs.copyBtn.onclick = () => copyAnswer(refs.answerEl, refs.copyBtn);
            refs.docxBtn.onclick = () => downloadDocx(question, answerMd, shown, refs.docxBtn);
        }
    }

    function ask(question) {
        if (activeES) return; // one stream at a time
        if (!canAsk()) { renderAskability(); return; }
        collapseExamples(); // zwiń panel, ale zostaw przycisk z przykładami dostępny
        const refs = createMsg(question, true);
        refs.msg.scrollIntoView({ behavior: 'smooth', block: 'start' });

        let acc = '';
        let citations = [];
        let url = '/asystent/strumien?q=' + encodeURIComponent(question);
        const vol = scope ? scope.value : '';
        if (vol) url += '&volume=' + encodeURIComponent(vol);
        const es = new EventSource(url);
        activeES = es;
        setBusy(true);

        const finish = () => { es.close(); activeES = null; setBusy(false); };
        // Persist the completed exchange so it survives a page refresh.
        const complete = () => {
            const shown = finalSources(acc, citations);
            finalize(refs, question, acc, shown);
            if (acc.trim()) saveExchange({ q: question, a: acc, citations: shown });
        };

        es.addEventListener('citations', e => {
            // Retrieved candidates; the visible source list is decided on 'done'
            // from what the answer actually cites (avoids "no answer" + sources).
            citations = JSON.parse(e.data).citations || [];
            // Non-empty citations ⇒ the server is calling the LLM and spends a credit.
            if (citations.length) spendCredit();
            refs.statusEl.lastChild.textContent = ' Przygotowuję odpowiedź…';
        });
        es.addEventListener('token', e => {
            refs.statusEl.style.display = 'none';
            acc += JSON.parse(e.data).t;
            refs.answerEl.innerHTML = renderAnswer(acc, citations, refs.blockId);
            followIfAtBottom();
        });
        es.addEventListener('done', () => { finish(); complete(); });
        es.addEventListener('error', e => {
            refs.statusEl.style.display = 'none';
            let m = 'Wystąpił błąd połączenia.';
            try { if (e.data) m = JSON.parse(e.data).message || m; } catch (_) {}
            if (!acc) refs.answerEl.innerHTML = '<span class="text-danger">' + esc(m) + '</span>';
            finish();
        });

        // Stop button aborts this stream and keeps whatever streamed so far.
        stop.onclick = () => {
            if (activeES !== es) return;
            finish();
            if (acc.trim()) complete();
            else refs.answerEl.innerHTML = '<span class="text-muted">Zatrzymano.</span>';
        };
    }

    function copyAnswer(answerEl, btn) {
        const text = answerEl.innerText || answerEl.textContent || '';
        const done = () => {
            const old = btn.innerHTML;
            btn.innerHTML = '<i class="ti ti-check me-1"></i> Skopiowano';
            setTimeout(() => { btn.innerHTML = old; }, 1600);
        };
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(done).catch(() => {});
        } else {
            const ta = document.createElement('textarea');
            ta.value = text; document.body.appendChild(ta); ta.select();
            try { document.execCommand('copy'); done(); } catch (_) {}
            ta.remove();
        }
    }

    function downloadDocx(question, answer, citations, btn) {
        const old = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Tworzę…';
        fetch('/asystent/docx', {
            method: 'POST', headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ question, answer, citations })
        })
        .then(r => r.ok ? r.blob() : Promise.reject(new Error('Błąd zapisu')))
        .then(blob => {
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url; a.download = 'odpowiedz-wyszynski.docx';
            document.body.appendChild(a); a.click(); a.remove();
            URL.revokeObjectURL(url);
        })
        .catch(() => alert('Nie udało się zapisać pliku DOCX.'))
        .finally(() => { btn.disabled = false; btn.innerHTML = old; });
    }

    function submit() {
        if (activeES) return;
        const v = q.value.trim();
        if (!v) return;
        ask(v);
        q.value = ''; autosize();
    }
    function autosize() { q.style.height = 'auto'; q.style.height = Math.min(q.scrollHeight, 160) + 'px'; }

    // ── History archive (localStorage; survives refresh, stays on this device) ──
    // Scoped per user so a different account on the same browser never sees
    // another user's conversations.
    const HKEY = 'rag-history-v1:' + ({{ app.user ? app.user.id : 0 }});
    try { localStorage.removeItem('rag-history-v1'); } catch (_) {} // drop legacy shared key
    const HMAX = 50;
    const histbar = document.getElementById('rag-histbar');
    const histcount = document.getElementById('rag-histcount');
    const histclear = document.getElementById('rag-histclear');
    const histtoggle = document.getElementById('rag-histtoggle');
    const histchevron = document.getElementById('rag-histchevron');
    const histlist = document.getElementById('rag-histlist');

    function loadHistory() {
        try { const v = JSON.parse(localStorage.getItem(HKEY)); return Array.isArray(v) ? v : []; }
        catch (_) { return []; }
    }
    function persistHistory(list) {
        try { localStorage.setItem(HKEY, JSON.stringify(list.slice(-HMAX))); } catch (_) {}
    }
    function saveExchange(entry) {
        const list = loadHistory();
        list.push(entry);
        persistHistory(list);
        updateHistBar();
    }
    function updateHistBar() {
        const n = loadHistory().length;
        if (n > 0) {
            histbar.style.display = '';
            histcount.textContent = n === 1 ? '1 zapisana rozmowa' : n + ' zapisanych rozmów';
            rebuildHistList();
        } else {
            histbar.style.display = 'none';
            histlist.classList.remove('open');
            histtoggle.setAttribute('aria-expanded', 'false');
        }
    }

    // Quick-jump list built from what is currently shown in the thread.
    function rebuildHistList() {
        const msgs = Array.from(thread.querySelectorAll('.rag-msg'));
        histlist.innerHTML = '';
        msgs.forEach((m, i) => {
            const qt = (m.querySelector('.rag-q .bubble')?.textContent || '').trim();
            const item = document.createElement('button');
            item.type = 'button';
            item.className = 'rag-histitem';
            item.innerHTML = `<span class="qn">${i + 1}.</span><span class="qt"></span>`;
            item.querySelector('.qt').textContent = qt;
            item.addEventListener('click', () => {
                m.scrollIntoView({ behavior: 'smooth', block: 'start' });
                histlist.classList.remove('open');
                histtoggle.setAttribute('aria-expanded', 'false');
            });
            histlist.appendChild(item);
        });
    }

    histtoggle.addEventListener('click', () => {
        const open = histlist.classList.toggle('open');
        histtoggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        if (histchevron) histchevron.className = open ? 'ti ti-chevron-up' : 'ti ti-chevron-down';
    });
    function restoreHistory() {
        const list = loadHistory();
        if (!list.length) return;
        // Przykłady zostają dostępne (zwinięte) nawet gdy jest historia.
        collapseExamples();
        for (const e of list) {
            const refs = createMsg(e.q, false);
            finalize(refs, e.q, e.a || '', Array.isArray(e.citations) ? e.citations : []);
        }
        updateHistBar();
    }

    histclear.addEventListener('click', () => {
        if (!confirm('Usunąć całą zapisaną historię rozmów z tej przeglądarki?')) return;
        try { localStorage.removeItem(HKEY); } catch (_) {}
        thread.innerHTML = '';
        seq = 0;
        examples.style.display = '';
        updateHistBar();
    });

    send.addEventListener('click', submit);
    q.addEventListener('input', autosize);
    q.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); submit(); }
    });
    const exToggle = document.getElementById('rag-ex-toggle');
    const exPanel = document.getElementById('rag-ex-panel');
    if (exToggle) exToggle.addEventListener('click', () => {
        const open = exPanel.classList.toggle('open');
        exToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    // Zwija rozwijany panel przykładów, ale zostawia sam przycisk widoczny —
    // dzięki temu przykładowe pytania są dostępne także przy aktywnej rozmowie/historii.
    function collapseExamples() {
        if (exPanel) exPanel.classList.remove('open');
        if (exToggle) exToggle.setAttribute('aria-expanded', 'false');
    }
    examples.querySelectorAll('.rag-ex-q').forEach(b =>
        b.addEventListener('click', () => ask(b.textContent.trim())));

    restoreHistory();
    renderAskability();
})();
</script>
{% endblock %}
