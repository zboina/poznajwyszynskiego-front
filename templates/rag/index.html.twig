                    {% if not unlimited %}
                    <span class="rag-tray-credits" id="rag-credits" title="Pula pytań do asystenta">
                        Pozostało pytań: <strong id="rag-credits-n">{{ credits }}</strong>
                    </span>
                    {% endif %}
