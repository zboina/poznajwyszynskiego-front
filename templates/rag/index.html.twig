                    {% if volumes|length > 1 %}
                    <button type="button" class="rag-tray-btn" id="rag-scope-btn" data-pop-toggle="scope" aria-expanded="false">
                        <i class="ti ti-books"></i> <span id="rag-scope-label">Wszystkie tomy</span>
                        <i class="ti ti-chevron-down chev"></i>
