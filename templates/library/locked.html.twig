{% extends 'base.html.twig' %}

{% block title %}Biblioteka — Czytelnia VIP{% endblock %}
{% block body_class %}lib-shell{% endblock %}

{% block stylesheets %}{{ include('library/_theme.html.twig') }}{% endblock %}

{% block body %}
{% include 'partials/_navbar.html.twig' %}
<div class="biblioteka">
    <div class="lib-wrap">
        <div class="lib-locked">
            <div class="seal">
                <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                    <rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/><circle cx="12" cy="16" r="1.4"/>
                </svg>
            </div>
            <h1>Czytelnia dostępna dla Czytelników VIP</h1>
            <p>
                Biblioteka to spokojne miejsce do lektury całych tomów Dzieł Zebranych —
                tekst po tekście, z możliwością wysłuchania wybranych z nagrania.
                Ta sala otwiera się przed Czytelnikami&nbsp;VIP.
            </p>

            {# Oferta dostępu — założenia wstępne: 30 dni za min. 100 zł (może być więcej). #}
            <div class="lib-offer">
                <div class="lib-offer-lead">Otwórz Czytelnię dla siebie</div>
                <div class="lib-offer-head">Dostęp VIP na 30 dni</div>
                <div class="lib-offer-price">od <strong>100&nbsp;zł</strong></div>
                <div class="lib-offer-note">
                    Wystarczy jednorazowa wpłata min. 100&nbsp;zł — kwotę możesz podnieść wedle uznania.
                    Przez 30 dni czytasz całe tomy i słuchasz nagrań bez ograniczeń.
                </div>
            </div>

            {% for msg in app.flashes('error') %}
                <div class="lib-flash-error">{{ msg }}</div>
            {% endfor %}

            {% if app.user and stripeConfigured|default(false) %}
                {# Pay-what-you-want od progu w górę. Rolę nadaje dopiero webhook Stripe. #}
                <form method="post" action="{{ path('app_vip_checkout') }}" class="lib-offer-form" data-turbo="false">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('vip') }}">
                    <div class="lib-amount">
                        <input type="number" name="amount" min="{{ vipMinPln|default(100) }}" step="1"
                               value="{{ vipMinPln|default(100) }}" inputmode="numeric"
                               aria-label="Kwota wpłaty w złotych">
                        <span class="lib-amount-cur">zł</span>
                    </div>
                    <button type="submit" class="lib-cta">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 11V7a4 4 0 0 1 8 0v4"/><rect x="5" y="11" width="14" height="10" rx="2"/><circle cx="12" cy="16" r="1.2"/></svg>
                        Wykup dostęp VIP na {{ vipPeriodDays|default(30) }} dni
                    </button>
                    <div class="lib-offer-methods">BLIK · karta · Przelewy24 — bezpiecznie przez Stripe</div>
                </form>
            {% elseif not app.user %}
                <a class="lib-cta" href="{{ path('app_login') }}">Zaloguj się, aby wykupić dostęp</a>
            {% endif %}

            <div>
                <a class="lib-cta-2" href="{{ path('app_search') }}">Wróć do wyszukiwarki</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
