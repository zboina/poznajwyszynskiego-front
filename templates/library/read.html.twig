{% extends 'base.html.twig' %}

{% block title %}{{ doc.title }} — Biblioteka{% endblock %}
{% block body_class %}lib-shell lib-fixed{% endblock %}

{% block stylesheets %}{{ include('library/_theme.html.twig') }}{{ include('partials/_document_text.html.twig') }}{% endblock %}

{% block body %}
{% include 'partials/_navbar.html.twig' %}
<div class="biblioteka">
    <div class="lib-wrap" id="readerRoot" data-reader-root>
        <div class="reader-topbar">
            <a class="lib-back" href="{{ path('app_library_volume', {id: doc.volume_id}) }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 6l-6 6 6 6"/></svg>
                {% if doc.volume_number %}Tom {{ doc.volume_number }}{% else %}Spis tekstów{% endif %}{% if doc.volume_title %} — {{ doc.volume_title }}{% endif %}
            </a>
        </div>

        {{ include('partials/_reader_tools.html.twig', {}, with_context: false) }}

        <div class="parchment" style="margin-top: 1rem;">
            <div class="reader">
                <div class="reader-kicker">{% if doc.document_type %}{{ doc.document_type|capitalize }}{% else %}Tekst{% endif %}{% if doc.volume_number %} · Tom {{ doc.volume_number }}{% endif %}</div>
                <h1 class="reader-title">{{ doc.title }}</h1>
                {% if doc.subtitle %}<div class="reader-sub">{{ doc.subtitle }}</div>{% endif %}
                {% if doc.location or doc.event_date_text %}
                    <div class="reader-meta">
                        {{ doc.location }}{% if doc.location and doc.event_date_text %}, {% endif %}{{ doc.event_date_text }}
                    </div>
                {% endif %}

                {% if audioUrl %}
                    <div class="lib-audio" id="lib-audio" data-doc-id="{{ doc.id }}" data-user="{{ app.user ? app.user.id : 'guest' }}">
                        <div class="lib-audio-head">
                            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4z"/><path d="M15.5 8.5a5 5 0 0 1 0 7"/><path d="M19 5a9 9 0 0 1 0 14"/></svg>
                            {{ audio.title ?? 'Posłuchaj lektury tego tekstu' }}
                        </div>
                        <audio class="lib-audio-el" id="lib-audio-el" controls preload="metadata">
                            <source src="{{ audioUrl }}" type="{{ audio.mime }}">
                            Twoja przeglądarka nie obsługuje odtwarzania audio.
                        </audio>
                    </div>
                {% endif %}

                <div class="reader-orn">❧</div>

                <div class="reader-body pw-doc">
                    {{ content|raw }}
                </div>

                <div class="reader-nav">
                    {% if prev %}
                        <a class="rnav" href="{{ path('app_library_read', {id: prev.id}) }}">
                            <span class="rnav-label">‹ Poprzedni</span>
                            <span class="rnav-title">{{ prev.title }}</span>
                        </a>
                    {% else %}
                        <span class="rnav rnav-empty"><span class="rnav-label">Początek tomu</span></span>
                    {% endif %}
                    {% if next %}
                        <a class="rnav next" href="{{ path('app_library_read', {id: next.id}) }}">
                            <span class="rnav-label">Następny ›</span>
                            <span class="rnav-title">{{ next.title }}</span>
                        </a>
                    {% else %}
                        <span class="rnav next rnav-empty"><span class="rnav-label">Koniec tomu</span></span>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

{% if audioUrl %}
<script>
(function () {
    var wrap = document.getElementById('lib-audio');
    var audio = document.getElementById('lib-audio-el');
    if (!wrap || !audio) return;

    // Wznawianie pozycji — wspólny klucz z widokiem wyszukiwarki.
    var key = 'pw_audio:' + (wrap.dataset.user || 'guest') + ':' + (wrap.dataset.docId || '0');
    var restore = function () {
        try {
            var s = parseFloat(localStorage.getItem(key) || '');
            if (s > 0 && (!audio.duration || s < audio.duration - 1)) audio.currentTime = s;
        } catch (e) {}
    };
    if (audio.readyState >= 1) restore(); else audio.addEventListener('loadedmetadata', restore, { once: true });
    var save = function () {
        try {
            if (audio.currentTime > 0 && (!audio.duration || audio.currentTime < audio.duration - 1)) localStorage.setItem(key, String(audio.currentTime));
        } catch (e) {}
    };
    var last = 0;
    audio.addEventListener('timeupdate', function () { if (Math.abs(audio.currentTime - last) >= 5) { last = audio.currentTime; save(); } });
    audio.addEventListener('pause', save);
    audio.addEventListener('ended', function () { try { localStorage.removeItem(key); } catch (e) {} });

    // Własny odtwarzacz z wyraźnym uchwytem postępu.
    var playIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M7 4v16l13 -8z"/></svg>';
    var pauseIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6 5h4v14h-4z"/><path d="M14 5h4v14h-4z"/></svg>';
    var fmt = function (t) { if (!isFinite(t) || t < 0) t = 0; var m = Math.floor(t / 60), s = Math.floor(t % 60); return m + ':' + String(s).padStart(2, '0'); };

    var ui = document.createElement('div');
    ui.className = 'pw-audio';
    ui.innerHTML =
        '<button type="button" class="pw-audio-btn" aria-label="Odtwórz">' + playIcon + '</button>' +
        '<span class="pw-audio-time pw-audio-cur">0:00</span>' +
        '<div class="pw-audio-track" role="slider" tabindex="0" aria-label="Pasek postępu nagrania" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">' +
            '<div class="pw-audio-fill"></div><div class="pw-audio-thumb"></div>' +
        '</div>' +
        '<span class="pw-audio-time pw-audio-dur">0:00</span>';
    audio.setAttribute('controls', '');
    audio.removeAttribute('controls');
    audio.style.display = 'none';
    audio.insertAdjacentElement('afterend', ui);

    var btn = ui.querySelector('.pw-audio-btn'), track = ui.querySelector('.pw-audio-track');
    var fill = ui.querySelector('.pw-audio-fill'), thumb = ui.querySelector('.pw-audio-thumb');
    var curEl = ui.querySelector('.pw-audio-cur'), durEl = ui.querySelector('.pw-audio-dur');

    var setProgress = function (r) { r = Math.min(1, Math.max(0, r || 0)); var p = (r * 100) + '%'; fill.style.width = p; thumb.style.left = p; track.setAttribute('aria-valuenow', String(Math.round(r * 100))); };
    var refresh = function () { var d = audio.duration || 0; setProgress(d ? audio.currentTime / d : 0); curEl.textContent = fmt(audio.currentTime); };
    var setIcon = function () { btn.innerHTML = audio.paused ? playIcon : pauseIcon; btn.setAttribute('aria-label', audio.paused ? 'Odtwórz' : 'Pauza'); };
    var showDur = function () { durEl.textContent = fmt(audio.duration); refresh(); };

    btn.addEventListener('click', function () { audio.paused ? audio.play() : audio.pause(); });
    audio.addEventListener('play', setIcon);
    audio.addEventListener('pause', setIcon);
    audio.addEventListener('timeupdate', refresh);
    audio.addEventListener('loadedmetadata', showDur);
    if (audio.readyState >= 1) showDur();
    setIcon();

    var seekTo = function (x) { var r = track.getBoundingClientRect(); var ratio = r.width ? (x - r.left) / r.width : 0; setProgress(ratio); if (audio.duration) audio.currentTime = Math.min(1, Math.max(0, ratio)) * audio.duration; curEl.textContent = fmt(audio.currentTime); };
    var dragging = false;
    track.addEventListener('pointerdown', function (e) { dragging = true; ui.classList.add('pw-dragging'); try { track.setPointerCapture(e.pointerId); } catch (_) {} seekTo(e.clientX); });
    track.addEventListener('pointermove', function (e) { if (dragging) seekTo(e.clientX); });
    var end = function () { dragging = false; ui.classList.remove('pw-dragging'); };
    track.addEventListener('pointerup', end);
    track.addEventListener('pointercancel', end);
    track.addEventListener('keydown', function (e) {
        if (!audio.duration) return;
        if (e.key === 'ArrowRight') { audio.currentTime = Math.min(audio.duration, audio.currentTime + 5); e.preventDefault(); }
        else if (e.key === 'ArrowLeft') { audio.currentTime = Math.max(0, audio.currentTime - 5); e.preventDefault(); }
    });
})();
</script>
{% endif %}
{% endblock %}
