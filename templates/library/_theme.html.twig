{# Wspólny motyw Biblioteki — klimat starej czytelni: drewno, pergamin, złoto. #}
<style>
    /* Tło biblioteki jako NIERUCHOMA warstwa (fixed ::before) — nigdy się nie przewija. */
    body.lib-shell { min-height: 100vh; background-color: #1c0f07; }
    body.lib-shell::before { content: ""; position: fixed; inset: 0; z-index: -1; pointer-events: none;
        background-color: #211308;
        background-image:
            radial-gradient(120% 90% at 50% -10%, rgba(201,162,39,.10), transparent 60%),
            repeating-linear-gradient(90deg, rgba(0,0,0,.22) 0 3px, rgba(0,0,0,0) 3px 9px),
            linear-gradient(180deg, #3a2414 0%, #2a1810 45%, #1c0f07 100%);
        box-shadow: inset 0 0 240px rgba(0,0,0,.6); }
    .biblioteka {
        --lib-gold: #C9A227;
        --lib-gold-lt: #e6cd78;
        --lib-wine: #722F37;
        --lib-ink: #33281a;
        --lib-ink-soft: #6b5a3e;
        --lib-parch-1: #f7efd8;
        --lib-parch-2: #ece0be;
        --lib-parch-edge: #d8c69a;
        color: #ecdcb8;
        font-family: 'EB Garamond', 'Cormorant Garamond', Georgia, serif;
    }
    .lib-wrap { max-width: 1120px; margin: 0 auto; padding: 2.4rem 1.25rem 4rem; }

    /* ── Nagłówek działu ── */
    .lib-head { text-align: center; margin-bottom: 2.2rem; }
    .lib-eyebrow { display: inline-flex; align-items: center; gap: .6rem; color: var(--lib-gold); letter-spacing: .32em; text-transform: uppercase; font-size: .72rem; font-family: 'Inter', sans-serif; font-weight: 600; }
    .lib-eyebrow::before, .lib-eyebrow::after { content: ""; width: 34px; height: 1px; background: linear-gradient(90deg, transparent, var(--lib-gold)); }
    .lib-eyebrow::after { background: linear-gradient(90deg, var(--lib-gold), transparent); }
    .lib-title { font-family: 'Playfair Display', Georgia, serif; font-weight: 800; font-size: clamp(2.1rem, 4vw, 3.2rem); color: #f6ead0; margin: .5rem 0 .35rem; text-shadow: 0 2px 0 rgba(0,0,0,.4), 0 0 26px rgba(201,162,39,.18); }
    .lib-sub { color: #c9b58c; font-size: 1.08rem; font-style: italic; max-width: 640px; margin: 0 auto; }
    .lib-rule { width: 120px; height: 2px; margin: 1.3rem auto 0; background: linear-gradient(90deg, transparent, var(--lib-gold), transparent); }

    /* ── Powrót / okruszki ── */
    .lib-back { display: inline-flex; align-items: center; gap: .45rem; color: #d8c48f; text-decoration: none; font-family: 'Inter', sans-serif; font-size: .86rem; padding: .35rem .2rem; transition: color .15s; }
    .lib-back:hover { color: var(--lib-gold-lt); }

    /* ── Regał ── */
    /* Półka docinana do zawartości — deska obejmuje dokładnie tyle, ile stoi książek. */
    .shelf { position: relative; width: fit-content; max-width: 100%; margin: 0 auto 2.7rem; padding: 0 1rem 22px; }
    .shelf-books { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: center; gap: 14px; min-height: 232px; padding: 0 8px; }
    .shelf-plank { position: absolute; left: 0; right: 0; bottom: 0; height: 22px; border-radius: 3px;
        background: linear-gradient(180deg, #6b4523, #3c2413 60%, #24140a);
        box-shadow: 0 10px 22px rgba(0,0,0,.55), inset 0 2px 0 rgba(255,220,150,.14), inset 0 -3px 6px rgba(0,0,0,.5); }
    .shelf-plank::before { content: ""; position: absolute; left: 0; right: 0; top: -3px; height: 3px; background: linear-gradient(180deg, rgba(255,225,160,.18), transparent); }

    .book { position: relative; width: 62px; height: 224px; cursor: pointer; text-decoration: none;
        border-radius: 3px 5px 5px 3px; padding: 12px 0;
        display: flex; flex-direction: column; align-items: center; justify-content: space-between;
        box-shadow: inset -6px 0 10px rgba(0,0,0,.35), inset 3px 0 4px rgba(255,255,255,.10), 0 8px 14px rgba(0,0,0,.4);
        transition: transform .18s ease, box-shadow .18s ease; transform-origin: bottom center; }
    .book::after { content: ""; position: absolute; inset: 0; border-radius: 3px 5px 5px 3px; pointer-events: none;
        background: repeating-linear-gradient(90deg, rgba(255,255,255,.05) 0 1px, transparent 1px 5px); opacity: .5; }
    .book:hover { transform: translateY(-14px) rotate(-1.5deg); box-shadow: inset -6px 0 10px rgba(0,0,0,.35), 0 18px 26px rgba(0,0,0,.55), 0 0 0 1px rgba(201,162,39,.4); }
    .book-band { width: 100%; height: 2px; background: linear-gradient(90deg, transparent, var(--lib-gold-lt), transparent); opacity: .85; }
    .book-title { writing-mode: vertical-rl; transform: rotate(180deg); font-family: 'Cormorant Garamond', serif; font-weight: 700;
        font-size: .96rem; line-height: 1.05; letter-spacing: .02em; color: #f3e4bd; text-shadow: 0 1px 1px rgba(0,0,0,.55);
        max-height: 150px; overflow: hidden; text-align: center; }
    .book-plate { display: flex; flex-direction: column; align-items: center; gap: 3px; text-align: center; max-width: 100%; padding: 0 4px; }
    .book-vol-name { font-family: 'Cormorant Garamond', serif; font-weight: 700; font-size: .66rem; letter-spacing: .05em; text-transform: uppercase; color: var(--lib-gold-lt); line-height: 1.02; text-shadow: 0 1px 1px rgba(0,0,0,.55); }
    .book-vol-years { font-family: 'Playfair Display', serif; font-weight: 700; font-size: .82rem; color: #f3e4bd; line-height: 1.1; white-space: nowrap; text-shadow: 0 1px 1px rgba(0,0,0,.55); }
    .book-num { font-family: 'Playfair Display', serif; font-weight: 700; font-size: .72rem; color: var(--lib-gold-lt); padding: 3px 9px; border-radius: 6px;
        border: 1px solid rgba(230,205,120,.5); background: rgba(0,0,0,.28); text-shadow: 0 1px 1px rgba(0,0,0,.6); white-space: nowrap; }
    .book-audio { position: absolute; top: 7px; right: 6px; color: var(--lib-gold-lt); opacity: .9; filter: drop-shadow(0 1px 1px rgba(0,0,0,.6)); }

    /* Skóry grzbietów — cykl po indeksie */
    .book-c0 { background: linear-gradient(90deg, #5a1f26, #7a2b33 55%, #4a181e); }
    .book-c1 { background: linear-gradient(90deg, #234b3a, #2f6349 55%, #1b3a2d); }
    .book-c2 { background: linear-gradient(90deg, #1f3a57, #285079 55%, #172c43); }
    .book-c3 { background: linear-gradient(90deg, #5a3d16, #7c5620 55%, #46300f); }
    .book-c4 { background: linear-gradient(90deg, #402046, #57305e 55%, #2f1834); }
    .book-c5 { background: linear-gradient(90deg, #4a3410, #6d4e16 55%, #382709); }

    /* ── Panel pergaminowy (wnętrze tomu / czytelnia) ── */
    .parchment { position: relative; border-radius: 6px; color: var(--lib-ink);
        background: radial-gradient(140% 120% at 50% 0, var(--lib-parch-1), var(--lib-parch-2) 70%, #e2d3ac 100%);
        border: 1px solid var(--lib-parch-edge);
        box-shadow: inset 0 0 70px rgba(120,85,30,.16), inset 0 0 0 6px rgba(255,255,255,.35), 0 18px 44px rgba(0,0,0,.5); }
    .parchment::before { content: ""; position: absolute; inset: 10px; border: 1px solid rgba(160,120,50,.35); border-radius: 3px; pointer-events: none; }

    /* ── Spis treści ── */
    .toc-vol { text-align: center; padding: 2rem 1.5rem 1.2rem; }
    .toc-vol-num { font-family: 'Inter', sans-serif; text-transform: uppercase; letter-spacing: .28em; font-size: .72rem; color: var(--lib-wine); font-weight: 700; }
    .toc-vol-title { font-family: 'Playfair Display', serif; font-weight: 700; font-size: clamp(1.5rem, 3vw, 2.1rem); color: #2a2013; margin: .35rem 0 .2rem; }
    .toc-vol-years { color: var(--lib-ink-soft); font-style: italic; }
    .toc-list { list-style: none; margin: 0; padding: .5rem 1.4rem 2rem; }
    .toc-item { position: relative; }
    .toc-link { display: flex; align-items: baseline; gap: .5rem; padding: .62rem .4rem; text-decoration: none; color: var(--lib-ink); border-radius: 4px; transition: background .15s; }
    .toc-link:hover { background: rgba(122,47,55,.07); }
    .toc-num { flex: 0 0 auto; font-family: 'Playfair Display', serif; color: var(--lib-wine); font-weight: 700; min-width: 2.1em; text-align: right; }
    .toc-name { font-size: 1.08rem; font-weight: 500; }
    .toc-dots { flex: 1 1 auto; border-bottom: 1px dotted rgba(90,60,20,.45); transform: translateY(-4px); }
    .toc-meta { flex: 0 0 auto; color: var(--lib-ink-soft); font-size: .82rem; font-style: italic; display: inline-flex; align-items: center; gap: .5rem; }
    .toc-audio { color: var(--lib-wine); display: inline-flex; align-items: center; }
    .toc-sep { border: 0; border-top: 1px solid rgba(150,110,50,.22); margin: 0 1.4rem; }

    /* ── Czytelnia ── */
    .reader { padding: 2.6rem clamp(1.2rem, 5vw, 3.6rem) 3rem; }
    .reader-kicker { text-align: center; font-family: 'Inter', sans-serif; text-transform: uppercase; letter-spacing: .26em; font-size: .7rem; color: var(--lib-wine); font-weight: 700; }
    .reader-title { text-align: center; font-family: 'Playfair Display', serif; font-weight: 700; font-size: clamp(1.6rem, 3.4vw, 2.4rem); color: #241a0e; margin: .5rem 0 .3rem; line-height: 1.2; }
    .reader-sub { text-align: center; color: var(--lib-ink-soft); font-style: italic; margin-bottom: .2rem; }
    .reader-meta { text-align: center; color: var(--lib-ink-soft); font-size: .9rem; margin-bottom: 1.4rem; }
    .reader-orn { text-align: center; color: var(--lib-wine); font-size: 1.3rem; letter-spacing: .4em; margin: 1rem 0 1.6rem; opacity: .7; }
    .reader-body { font-family: 'Lora', Georgia, serif; font-size: 1.16rem; line-height: 1.95; color: #2c2214; max-width: 46rem; margin: 0 auto; }
    .reader-body p { margin: 0 0 1.15em; text-indent: 1.6em; text-align: justify; }
    .reader-body p:first-of-type { text-indent: 0; }
    .reader-body p:first-of-type::first-letter { font-family: 'Playfair Display', serif; font-size: 3.2em; line-height: .82; float: left; margin: .06em .12em 0 0; color: var(--lib-wine); }
    .reader-body .page-marker { display: inline-block; color: var(--lib-wine); opacity: .6; font-size: .78em; font-style: italic; margin: 0 .2em; vertical-align: super; }
    .reader-body .footnote-ref a { color: var(--lib-wine); text-decoration: none; font-weight: 600; }
    .reader-body .footnotes { margin-top: 2.4rem; font-size: .92rem; color: #4a3a22; }
    .reader-body .footnotes hr { border: 0; border-top: 1px solid rgba(150,110,50,.35); margin-bottom: 1rem; }
    .reader-body .footnotes ol { padding-left: 1.4rem; }
    .reader-body .footnotes li { margin-bottom: .5em; text-indent: 0; }
    .reader-body .footnote-back { text-decoration: none; color: var(--lib-wine); }

    /* ── Nawigacja poprzedni/następny ── */
    .reader-nav { display: flex; justify-content: space-between; gap: 1rem; max-width: 46rem; margin: 2.6rem auto 0; }
    .reader-nav a, .reader-nav span { flex: 1 1 0; min-width: 0; }
    .rnav { display: block; text-decoration: none; color: var(--lib-ink); padding: .7rem .9rem; border: 1px solid rgba(150,110,50,.4);
        border-radius: 5px; background: rgba(255,255,255,.35); transition: background .15s, border-color .15s; }
    .rnav:hover { background: rgba(122,47,55,.08); border-color: var(--lib-wine); }
    .rnav.next { text-align: right; }
    .rnav-label { display: block; font-family: 'Inter', sans-serif; font-size: .68rem; text-transform: uppercase; letter-spacing: .18em; color: var(--lib-wine); font-weight: 700; }
    .rnav-title { display: block; font-family: 'Cormorant Garamond', serif; font-size: 1.05rem; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .rnav-empty { opacity: .35; }

    /* ── Player audio w czytelni ── */
    .lib-audio { max-width: 46rem; margin: 0 auto 1.8rem; padding: .9rem 1.1rem 1rem;
        border-radius: 8px; border: 1px solid rgba(150,110,50,.45);
        background: linear-gradient(180deg, rgba(58,36,20,.92), rgba(36,22,12,.95)); box-shadow: 0 8px 22px rgba(0,0,0,.4); }
    .lib-audio-head { display: flex; align-items: center; gap: .55rem; color: var(--lib-gold-lt); font-weight: 600; font-family: 'Inter', sans-serif; font-size: .82rem; letter-spacing: .04em; margin-bottom: .7rem; }
    .pw-audio { display: flex; align-items: center; gap: .7rem; }
    .pw-audio-btn { flex: 0 0 auto; width: 42px; height: 42px; border: 0; border-radius: 50%; background: var(--lib-gold); color: #2a1a06; display: grid; place-items: center; cursor: pointer; box-shadow: 0 2px 8px rgba(0,0,0,.4); transition: transform .08s, background .15s; }
    .pw-audio-btn:hover { background: var(--lib-gold-lt); }
    .pw-audio-btn:active { transform: scale(.94); }
    .pw-audio-time { flex: 0 0 auto; font-variant-numeric: tabular-nums; font-size: .8rem; color: #d8c48f; min-width: 2.7em; text-align: center; font-family: 'Inter', sans-serif; }
    .pw-audio-track { position: relative; flex: 1 1 auto; height: 8px; border-radius: 999px; background: rgba(220,196,140,.22); cursor: pointer; touch-action: none; }
    .pw-audio-fill { position: absolute; left: 0; top: 0; height: 100%; width: 0; border-radius: 999px; background: linear-gradient(90deg, #b7911f, var(--lib-gold-lt)); pointer-events: none; }
    .pw-audio-thumb { position: absolute; top: 50%; left: 0; width: 16px; height: 16px; border-radius: 50%; background: #fff8e6; border: 3px solid var(--lib-gold); box-shadow: 0 1px 5px rgba(0,0,0,.5); transform: translate(-50%,-50%); pointer-events: none; }
    .pw-audio-track:hover .pw-audio-thumb, .pw-audio.pw-dragging .pw-audio-thumb { box-shadow: 0 0 0 4px rgba(201,162,39,.28), 0 1px 5px rgba(0,0,0,.5); }
    .pw-audio-track:focus-visible { outline: 2px solid var(--lib-gold-lt); outline-offset: 4px; }

    /* ── Strona „zamknięta" (nie-VIP) ── */
    .lib-locked { max-width: 620px; margin: 0 auto; text-align: center; padding: 3rem 1.5rem; }
    .lib-locked .seal { width: 108px; height: 108px; margin: 0 auto 1.4rem; border-radius: 50%; display: grid; place-items: center;
        color: #f4e6c2; background: radial-gradient(circle at 35% 30%, #8a3a43, var(--lib-wine) 65%, #4a1c22);
        box-shadow: 0 10px 30px rgba(0,0,0,.5), inset 0 2px 6px rgba(255,255,255,.2); border: 3px solid rgba(201,162,39,.55); }
    .lib-locked h1 { font-family: 'Playfair Display', serif; color: #f6ead0; font-weight: 800; font-size: clamp(1.8rem,3.6vw,2.6rem); margin-bottom: .6rem; }
    .lib-locked p { color: #cbb488; font-size: 1.1rem; line-height: 1.7; max-width: 520px; margin: 0 auto 1.7rem; }
    .lib-cta { display: inline-flex; align-items: center; gap: .5rem; text-decoration: none; font-family: 'Inter', sans-serif; font-weight: 700;
        padding: .8rem 1.7rem; border-radius: 999px; color: #2a1a06; background: linear-gradient(180deg, var(--lib-gold-lt), var(--lib-gold));
        box-shadow: 0 8px 22px rgba(201,162,39,.3); transition: transform .12s, box-shadow .12s; }
    .lib-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 28px rgba(201,162,39,.42); color: #2a1a06; }
    .lib-cta-2 { display: inline-block; margin-top: 1rem; color: #b9a274; text-decoration: underline; font-family: 'Inter', sans-serif; font-size: .9rem; }

    .lib-empty { text-align: center; color: #c9b58c; font-style: italic; padding: 3rem 1rem; }

    /* ── Menu w klimacie biblioteki (drewno + jasne/złote napisy) ── */
    body.lib-shell .app-navbar { background: linear-gradient(180deg, #2c1a0e, #1c1008);
        box-shadow: 0 1px 0 rgba(201,162,39,.30), 0 6px 18px rgba(0,0,0,.5); border-bottom: 1px solid rgba(201,162,39,.28); }
    body.lib-shell .app-navbar .brand-mark, .lib-shell .app-navbar .brand-mark span { color: #f3e4bd; }
    body.lib-shell .app-navbar .brand-mark img { border-color: rgba(201,162,39,.6); }
    body.lib-shell .app-navbar .pwnav-link { color: #d9c8a2; }
    body.lib-shell .app-navbar .pwnav-link:hover { color: #f6ead0; background: rgba(201,162,39,.12); }
    body.lib-shell .app-navbar .pwnav-link.active { color: #f6ead0; background: rgba(201,162,39,.18); }
    body.lib-shell .app-navbar .user-pill { background: rgba(201,162,39,.10); border-color: rgba(201,162,39,.30); color: #f0e2c0; }
    body.lib-shell .app-navbar .admin-link { color: #cbb98f; border-color: rgba(201,162,39,.22); }
    body.lib-shell .app-navbar .admin-link:hover { color: #fff8e6; background: rgba(201,162,39,.12); border-color: rgba(201,162,39,.4); }
    body.lib-shell .app-navbar .btn-ghost-light { color: rgba(240,226,192,.72); }
    body.lib-shell .app-navbar .btn-ghost-light:hover { color: #fff8e6; }

    /* Widok tomu i czytania: menu przypięte (tło i tak jest już nieruchome globalnie). */
    body.lib-fixed .app-navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 250; }
    body.lib-fixed .biblioteka { padding-top: 56px; }

    @media (max-width: 640px) {
        .book { width: 54px; height: 200px; }
        .reader-nav { flex-direction: column; }
    }
</style>
