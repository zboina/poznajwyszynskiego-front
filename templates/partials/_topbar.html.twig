{# Wspólny górny pasek z nawigacją między widokami. Samodzielny (własny CSS),
   więc działa na stronach bez stylów wyszukiwarki (/asystent, /moje-konto). #}
{% set route = app.request.attributes.get('_route') %}
{% set isSearch = route starts with 'app_search' or route starts with 'app_document' %}
{% set isRag = route starts with 'app_rag' %}
{% set isAccount = route == 'app_account' %}

<style>
    .pwnav { background: #722F37; box-shadow: 0 2px 8px rgba(0,0,0,.15); position: relative; z-index: 200; }
    .pwnav-in { max-width: 1140px; margin: 0 auto; display: flex; align-items: center; gap: 1rem; padding: .55rem 1rem; }
    .pwnav-brand { display: flex; align-items: center; gap: .5rem; text-decoration: none; color: #fff; flex: 0 0 auto; }
    .pwnav-brand img { width: 30px; height: 30px; border-radius: 50%; border: 2px solid rgba(201,162,39,.45); }
    .pwnav-brand span { font-weight: 700; font-size: .9rem; }
    .pwnav-links { display: flex; align-items: center; gap: .25rem; margin-left: .5rem; flex: 1 1 auto; }
    .pwnav-link {
        display: inline-flex; align-items: center; gap: .35rem; text-decoration: none;
        color: rgba(255,255,255,.78); font-size: .85rem; font-weight: 600;
        padding: .4rem .7rem; border-radius: 8px; transition: background .15s, color .15s; }
    .pwnav-link:hover { color: #fff; background: rgba(255,255,255,.1); }
    .pwnav-link.active { color: #fff; background: rgba(255,255,255,.16); }
    .pwnav-right { display: flex; align-items: center; gap: .5rem; flex: 0 0 auto; }
    .pwnav-pill {
        display: inline-flex; align-items: center; gap: .35rem;
        background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.15);
        border-radius: 20px; padding: .25rem .65rem .25rem .45rem; color: #fff; font-size: .78rem;
        text-decoration: none; white-space: nowrap; }
    .pwnav-pill:hover { background: rgba(255,255,255,.2); color: #fff; }
    .pwnav-role { font-size: .6rem; padding: .1rem .4rem; border-radius: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }
    .pwnav-support {
        display: inline-flex; align-items: center; gap: .35rem; text-decoration: none;
        background: #C9A227; color: #1a1a1a; font-weight: 700; font-size: .8rem;
        padding: .35rem .8rem; border-radius: 20px; }
    .pwnav-support:hover { background: #d8b53a; color: #1a1a1a; }
    .pwnav-ghost { color: rgba(255,255,255,.7); text-decoration: none; font-size: .8rem; padding: .35rem .6rem; }
    .pwnav-ghost:hover { color: #fff; }
    @media (max-width: 640px) {
        .pwnav-brand span { display: none; }
        .pwnav-link span.t { display: none; }
        .pwnav-pill .nm { display: none; }
    }
</style>

<nav class="pwnav">
    <div class="pwnav-in">
        <a href="{{ path('app_search') }}" class="pwnav-brand">
            <img src="{{ asset('logo_PW_bez_obramowania.png') }}" alt="">
            <span>Dzieła Zebrane</span>
        </a>

        <div class="pwnav-links">
            <a href="{{ path('app_search') }}" class="pwnav-link {{ isSearch ? 'active' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="10" cy="10" r="7"/><path d="m21 21-6-6"/></svg>
                <span class="t">Wyszukiwarka</span>
            </a>
            <a href="{{ path('app_rag') }}" class="pwnav-link {{ isRag ? 'active' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 9h8M8 13h6"/><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <span class="t">Asystent AI</span>
            </a>
            {% if app.user %}
            <a href="{{ path('app_account') }}" class="pwnav-link {{ isAccount ? 'active' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21v-2a4 4 0 0 1 4-4h8a4 4 0 0 1 4 4v2"/></svg>
                <span class="t">Moje konto</span>
            </a>
            {% endif %}
        </div>

        <div class="pwnav-right">
            {% if app.user %}
                {% set role = 'User' %}{% set rbg = 'rgba(255,255,255,.2)' %}{% set rfg = '#fff' %}
                {% if 'ROLE_VIP' in app.user.roles %}{% set role = 'VIP' %}{% set rbg = '#C9A227' %}{% set rfg = '#1a1a1a' %}
                {% elseif 'ROLE_DONATOR' in app.user.roles %}{% set role = 'Donator' %}{% set rbg = '#2fb344' %}{% set rfg = '#fff' %}
                {% elseif 'ROLE_ADMIN' in app.user.roles or 'ROLE_SUPER_ADMIN' in app.user.roles %}{% set role = 'Admin' %}{% set rbg = '#e53e3e' %}{% set rfg = '#fff' %}{% endif %}
                <a href="{{ path('app_account') }}" class="pwnav-pill" title="Moje konto">
                    <span class="nm">{{ app.user.name ?? app.user.email }}</span>
                    <span class="pwnav-role" style="background:{{ rbg }};color:{{ rfg }};">{{ role }}</span>
                </a>
                <a href="{{ path('app_donate') }}" class="pwnav-support">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                    Wesprzyj
                </a>
                <a href="{{ path('app_logout') }}" class="pwnav-ghost">Wyloguj</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="pwnav-ghost">Zaloguj</a>
                <a href="{{ path('app_register') }}" class="pwnav-support">Załóż konto</a>
            {% endif %}
        </div>
    </div>
</nav>
