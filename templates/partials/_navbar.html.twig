{# ══════════════════════════════════════════════════════════════════════════
   Wspólny pasek nawigacji — JEDNO źródło markupu i stylów dla wszystkich
   widoków (wyszukiwarka, Asystent AI, Konto). Reaguje na motyw v1–v6:
   • na stronie wyszukiwarki klasa layout-* jest na .page (zarządza nią tamtejszy
     przełącznik),
   • na pozostałych stronach klasa jest nakładana na <body> skryptem na końcu.

   Parametry (opcjonalne):
   • navExtras (bool) – pokaż elementy zależne od JS wyszukiwarki
     (licznik „Moje podglądy", przycisk DEMO). Domyślnie false.
   ══════════════════════════════════════════════════════════════════════════ #}
{% set navExtras = navExtras|default(false) %}
{% set _route = app.request.attributes.get('_route') %}
{% set _isSearch = _route starts with 'app_search' or _route starts with 'app_document' %}
{% set _isRag = _route starts with 'app_rag' %}
{% set _isLibrary = _route starts with 'app_library' %}

<style>
    .app-navbar { background: #722F37; box-shadow: 0 2px 8px rgba(0,0,0,.15); position: relative; z-index: 200; }
    .brand-mark { display: flex; align-items: center; gap: .5rem; text-decoration: none; color: #fff; }
    .brand-mark img { border: 2px solid rgba(201,162,39,.45); }
    .brand-mark span { font-weight: 700; font-size: .9rem; letter-spacing: .01em; }
    .nav-links-c { display: flex; align-items: center; gap: .25rem; }
    .app-navbar .pwnav-link {
        display: inline-flex; align-items: center; gap: .35rem; text-decoration: none;
        color: rgba(255,255,255,.78); font-size: .85rem; font-weight: 600;
        padding: .4rem .7rem; border-radius: 8px; transition: background .15s, color .15s; }
    .app-navbar .pwnav-link:hover { color: #fff; background: rgba(255,255,255,.1); }
    .app-navbar .pwnav-link.active { color: #fff; background: rgba(255,255,255,.16); }
    .user-pill {
        display: inline-flex; align-items: center; gap: .35rem;
        background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.15);
        border-radius: 20px; padding: .25rem .65rem .25rem .45rem;
        color: #fff; font-size: .78rem; white-space: nowrap; }
    .user-pill .role-badge, .role-badge {
        font-size: .6rem; padding: .1rem .4rem; border-radius: 10px; font-weight: 700;
        text-transform: uppercase; letter-spacing: .04em; }
    .views-pill {
        display: inline-flex; align-items: center; gap: .3rem; cursor: pointer;
        background: rgba(201,162,39,.2); border: 1px solid rgba(201,162,39,.3);
        border-radius: 20px; padding: .2rem .6rem; color: #C9A227; font-size: .75rem; font-weight: 600; }
    .views-pill:hover { background: rgba(201,162,39,.3); }
    .admin-link {
        display: inline-flex; align-items: center; gap: .3rem; text-decoration: none;
        color: rgba(255,255,255,.6); font-size: .75rem; font-weight: 600;
        padding: .2rem .55rem; border-radius: 6px; border: 1px solid rgba(255,255,255,.12); transition: all .15s; }
    .admin-link:hover { color: #fff; background: rgba(255,255,255,.1); border-color: rgba(255,255,255,.25); }
    .app-navbar .btn-ghost-light { color: rgba(255,255,255,.7); }
    .app-navbar .btn-ghost-light:hover { color: #fff; }

    /* ── Warianty motywów (layout-* na .page LUB na <body>) ── */
    /* v2 — minimalistyczny, biały pasek */
    .layout-v2 .app-navbar { background: #fff; box-shadow: 0 1px 0 #e8e0d4; }
    .layout-v2 .app-navbar .brand-mark { color: #1a1a1a; }
    .layout-v2 .app-navbar .brand-mark img { border-color: #e8e0d4; }
    .layout-v2 .app-navbar .pwnav-link { color: rgba(26,26,26,.7); }
    .layout-v2 .app-navbar .pwnav-link:hover,
    .layout-v2 .app-navbar .pwnav-link.active { color: #1a1a1a; background: rgba(0,0,0,.06); }
    .layout-v2 .user-pill { background: #f5f3ef; border-color: #e8e0d4; color: #555; }
    .layout-v2 .views-pill { background: rgba(114,47,55,.06); border-color: rgba(114,47,55,.12); color: #722F37; }
    .layout-v2 .admin-link { color: #999; border-color: #e0dbd5; }
    .layout-v2 .admin-link:hover { color: #722F37; border-color: #722F37; background: rgba(114,47,55,.04); }
    .layout-v2 .app-navbar .btn-ghost-light { color: #999; }
    .layout-v2 .app-navbar .btn-ghost-light:hover { color: #722F37; }
    /* v3 / v4 — navy */
    .layout-v3 .app-navbar, .layout-v4 .app-navbar { background: #1A365D; box-shadow: none; }
    .layout-v3 .app-navbar .brand-mark img, .layout-v4 .app-navbar .brand-mark img {
        border-color: rgba(201,162,39,.5); box-shadow: 0 0 12px rgba(201,162,39,.2); width: 34px; height: 34px; }
    .layout-v3 .app-navbar .brand-mark span, .layout-v4 .app-navbar .brand-mark span {
        font-size: .95rem; text-shadow: 0 1px 4px rgba(0,0,0,.2); }
    .layout-v3 .user-pill, .layout-v4 .user-pill {
        background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.12); color: rgba(255,255,255,.85); }
    .layout-v3 .views-pill, .layout-v4 .views-pill {
        background: rgba(201,162,39,.15); border-color: rgba(201,162,39,.25); color: #C9A227; }
    .layout-v3 .app-navbar .btn-ghost-light, .layout-v4 .app-navbar .btn-ghost-light { color: rgba(255,255,255,.5); }
    .layout-v3 .app-navbar .btn-ghost-light:hover, .layout-v4 .app-navbar .btn-ghost-light:hover { color: #fff; }
    /* v5 — bordo */
    .layout-v5 .app-navbar { background: #5C2630; box-shadow: none; }
    .layout-v5 .app-navbar .brand-mark img { border-color: rgba(201,162,39,.5); box-shadow: 0 0 12px rgba(201,162,39,.2); width: 34px; height: 34px; }
    .layout-v5 .app-navbar .brand-mark span { font-size: .95rem; text-shadow: 0 1px 4px rgba(0,0,0,.2); }
    .layout-v5 .user-pill { background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.12); color: rgba(255,255,255,.85); }
    .layout-v5 .views-pill { background: rgba(201,162,39,.15); border-color: rgba(201,162,39,.25); color: #C9A227; }
    .layout-v5 .app-navbar .btn-ghost-light { color: rgba(255,255,255,.5); }
    .layout-v5 .app-navbar .btn-ghost-light:hover { color: #fff; }
    /* v6 — jasny */
    .layout-v6 .app-navbar { background: #fff; box-shadow: 0 1px 0 #e8e0d4; }
    .layout-v6 .app-navbar .brand-mark { color: #1a1a1a; }
    .layout-v6 .app-navbar .brand-mark img { border-color: #e8e0d4; width: 34px; height: 34px; }
    .layout-v6 .app-navbar .brand-mark span { font-size: .95rem; color: #2D2D2D; }
    .layout-v6 .app-navbar .pwnav-link { color: rgba(26,26,26,.7); }
    .layout-v6 .app-navbar .pwnav-link:hover { color: #722F37; background: rgba(114,47,55,.06); }
    .layout-v6 .app-navbar .pwnav-link.active { color: #722F37; background: rgba(114,47,55,.08); }
    .layout-v6 .user-pill { background: #f5f3ef; border-color: #e8e0d4; color: #555; }
    .layout-v6 .views-pill { background: rgba(114,47,55,.06); border-color: rgba(114,47,55,.12); color: #722F37; }
    .layout-v6 .admin-link { color: #999; border-color: #e0dbd5; }
    .layout-v6 .admin-link:hover { color: #722F37; border-color: #722F37; background: rgba(114,47,55,.04); }
    .layout-v6 .app-navbar .btn-ghost-light { color: #999; }
    .layout-v6 .app-navbar .btn-ghost-light:hover { color: #722F37; }

    /* ── Menu responsywne: hamburger na wąskich ekranach ── */
    .nav-menu { display: flex; align-items: center; flex: 1 1 auto; gap: .5rem; }
    .nav-menu .nav-links-c { margin-inline: auto; }
    /* Złoty przycisk — mocny kontrast na KAŻDYM motywie (ciemnym i jasnym). */
    .nav-toggle { display: none; align-items: center; justify-content: center; width: 46px; height: 40px;
        padding: 0; color: #2a1a06; background: #C9A227; border: 1px solid rgba(0,0,0,.2);
        border-radius: 8px; cursor: pointer; box-shadow: 0 1px 5px rgba(0,0,0,.35); transition: background .15s; }
    .nav-toggle:hover { background: #dab63c; }
    .nav-mobile-title { display: none; }

    @media (max-width: 860px) {
        /* Hamburger po LEWEJ, zgrupowany z logo; menu rozwija się pod paskiem. */
        .app-navbar .container-xl { flex-wrap: wrap; justify-content: flex-start; gap: .55rem .7rem; }
        /* Układ mobilny paska: ☰ lewo · „Poznaj Wyszyńskiego" środek · logo prawo. */
        .nav-toggle { display: inline-flex; order: 0; }
        .nav-mobile-title { display: block; order: 1; flex: 1 1 auto; min-width: 0; text-align: center;
            color: #fff; font-family: 'Playfair Display', Georgia, serif; font-weight: 700;
            font-size: clamp(.95rem, 4.2vw, 1.15rem); white-space: nowrap; overflow: hidden;
            text-overflow: ellipsis; letter-spacing: .01em; text-shadow: 0 1px 2px rgba(0,0,0,.4); }
        .layout-v2 .nav-mobile-title, .layout-v6 .nav-mobile-title { color: #1a1a1a; text-shadow: none; }
        .brand-mark { order: 2; margin: 0; }
        .brand-mark span { display: none; }
        /* Zwinięte menu = display:none → NIE zajmuje wysokości, więc rząd
           ☰/tytuł/logo jest wyśrodkowany w pionie belki. */
        .nav-menu { order: 3; flex-basis: 100%; display: none; flex-direction: column; align-items: stretch;
            gap: .3rem; margin-top: .5rem; padding-top: .55rem; border-top: 1px solid rgba(255,255,255,.16); }
        .nav-menu.open { display: flex; max-height: 78vh; overflow-y: auto; }
        .layout-v2 .nav-menu, .layout-v6 .nav-menu { border-top-color: rgba(0,0,0,.1); }
        .nav-menu .nav-links-c { flex-direction: column; align-items: stretch; margin: 0; gap: .2rem; }
        .nav-menu .nav-links-c .t { display: inline !important; }
        /* Każda pozycja jako wyraźny, kontrastowy wiersz — czytelne na ciemnym pasku. */
        .app-navbar .pwnav-link { padding: .68rem .8rem; font-size: .96rem; border-radius: 8px;
            background: rgba(255,255,255,.06); }
        .app-navbar .pwnav-link.active { background: rgba(255,255,255,.2); }
        .layout-v2 .app-navbar .pwnav-link, .layout-v6 .app-navbar .pwnav-link { background: rgba(0,0,0,.04); }
        .nav-actions { flex-direction: column; align-items: stretch; gap: .4rem; width: 100%; }
        .nav-actions > * { width: 100%; justify-content: center; }
        .user-pill { justify-content: center; padding: .5rem .7rem; }
    }
    @media (max-width: 640px) {
        .user-pill { font-size: .78rem; }
    }
</style>

<nav class="app-navbar">
    <div class="container-xl d-flex align-items-center justify-content-between py-2">
        <a href="{{ path('app_search') }}" class="brand-mark" {% if _isSearch %}data-action="click->search#goHome"{% endif %} style="text-decoration:none; color:inherit;">
            <img src="{{ asset('logo_PW_bez_obramowania.png') }}" alt="" width="30" height="30" class="rounded-circle">
            <span>Dzieła Zebrane</span>
        </a>
        <span class="nav-mobile-title" aria-hidden="true">Poznaj Wyszyńskiego</span>
        <button type="button" class="nav-toggle" id="appNavToggle" aria-label="Menu" aria-expanded="false" aria-controls="appNavMenu">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <div class="nav-menu" id="appNavMenu">
        <div class="nav-links-c">
            {# Bez logowania dostępna jest tylko wyszukiwarka — pojedynczy link nie ma
               sensu. Przełącznik Wyszukiwarka/Asystent pokazujemy dopiero zalogowanym. #}
            {% if app.user %}
            <a href="{{ path('app_search') }}" class="pwnav-link {{ _isSearch ? 'active' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="10" cy="10" r="7"/><path d="m21 21-6-6"/></svg>
                <span class="t">Wyszukiwarka</span>
            </a>
            <a href="{{ path('app_rag') }}" class="pwnav-link {{ _isRag ? 'active' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 9h8M8 13h6"/><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <span class="t">Asystent AI</span>
            </a>
            <a href="{{ path('app_library') }}" class="pwnav-link {{ _isLibrary ? 'active' }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19V5a1 1 0 0 1 1-1h4v16H5a1 1 0 0 1-1-1z"/><path d="M9 4h5v16H9z"/><path d="m14 5 4 .8 2.5 13.5-4 .7"/></svg>
                <span class="t">Biblioteka</span>
            </a>
            {% endif %}
        </div>
        <div class="nav-actions d-flex align-items-center gap-2">
            {% if app.user %}
                <a href="{{ path('app_account') }}" class="user-pill" style="text-decoration:none;color:inherit;" title="Moje konto">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" style="opacity:.6;"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><circle cx="12" cy="7" r="4"/><path d="M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2"/></svg>
                    {{ app.user.name ?? app.user.email }}
                    {% if 'ROLE_SUPER_ADMIN' in app.user.roles %}
                        <span class="role-badge" style="background:#e53e3e; color:#fff;">Admin</span>
                    {% elseif 'ROLE_REDAKTOR' in app.user.roles %}
                        <span class="role-badge" style="background:#6366f1; color:#fff;">Redaktor</span>
                    {% elseif 'ROLE_EDYTOR' in app.user.roles %}
                        <span class="role-badge" style="background:#8b5cf6; color:#fff;">Edytor</span>
                    {% elseif 'ROLE_VIP' in app.user.roles %}
                        <span class="role-badge" style="background:#C9A227; color:#1a1a1a;">VIP</span>
                    {% elseif 'ROLE_DONATOR' in app.user.roles %}
                        <span class="role-badge" style="background:#2fb344; color:#fff;">Donator</span>
                    {% else %}
                        <span class="role-badge" style="background:rgba(255,255,255,.2); color:#fff;">User</span>
                    {% endif %}
                </a>
                {% if navExtras and accessLevel|default('') == 'user' and viewsRemaining is defined and viewsRemaining is not null %}
                    <div class="views-pill-wrap" style="position:relative;">
                        <button class="views-pill" data-action="click->search#toggleMyViews" title="Moje podglądy">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/><path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/></svg>
                            {{ viewsRemaining }}/5
                        </button>
                        <div class="my-views-dropdown" id="myViewsDropdown" data-search-target="myViewsDropdown">
                            <div class="mv-header">
                                <span>Moje podglądy (24h)</span>
                                <button class="mv-close" data-action="click->search#toggleMyViews">&times;</button>
                            </div>
                            <div class="mv-list" id="myViewsList">
                                <div class="mv-empty">Ładowanie...</div>
                            </div>
                        </div>
                    </div>
                {% endif %}
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_admin_users') }}" class="admin-link" title="Panel admina">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10.325 4.317c.426 -1.756 2.924 -1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543 -.94 3.31 .826 2.37 2.37a1.724 1.724 0 0 0 1.066 2.573c1.756 .426 1.756 2.924 0 3.35a1.724 1.724 0 0 0 -1.066 2.573c.94 1.543 -.826 3.31 -2.37 2.37a1.724 1.724 0 0 0 -2.573 1.066c-.426 1.756 -2.924 1.756 -3.35 0a1.724 1.724 0 0 0 -2.573 -1.066c-1.543 .94 -3.31 -.826 -2.37 -2.37a1.724 1.724 0 0 0 -1.066 -2.573c-1.756 -.426 -1.756 -2.924 0 -3.35a1.724 1.724 0 0 0 1.066 -2.573c-.94 -1.543 .826 -3.31 2.37 -2.37c1 .608 2.296 .07 2.572 -1.065z"/><circle cx="12" cy="12" r="3"/></svg>
                        Admin
                    </a>
                {% endif %}
                <a href="{{ path('app_donate') }}" class="btn btn-sm py-1 px-2 d-inline-flex align-items-center gap-1" style="font-size:.78rem; background:#C9A227; color:#1a1a1a; font-weight:700;" title="Wesprzyj projekt">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                    Wesprzyj
                </a>
                <a href="{{ path('app_logout') }}" class="btn btn-sm btn-ghost-light py-1 px-2" style="font-size: .78rem; opacity:.7;">Wyloguj</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-sm btn-ghost-light py-1 px-2">Zaloguj się</a>
                {% if navExtras and site_settings.demo|default(false) %}
                    <button type="button" id="navDemoBtn" class="btn btn-sm py-1 px-2" style="font-size:.65rem; letter-spacing:.1em; border: 1px solid rgba(201,162,39,.4); color: #C9A227; font-weight:700;">DEMO</button>
                {% else %}
                    <a href="{{ path('app_register') }}" class="btn btn-sm py-1 px-2" style="font-size:.78rem; background:#C9A227; color:#1a1a1a; font-weight:700;">Załóż konto</a>
                {% endif %}
            {% endif %}
        </div>
        </div>
    </div>
</nav>

{# Poza wyszukiwarką (brak .page z własnym przełącznikiem) nakładamy zapisany
   motyw na <body>, aby pasek i strona reagowały na styl. Uruchamiane wcześnie
   → pasek renderuje się od razu w docelowym kolorze. #}
<script>
(function () {
    if (document.querySelector('.page')) return; // wyszukiwarka zarządza motywem sama
    try {
        var v = localStorage.getItem('pw_layout') || 'v1';
        var b = document.body;
        b.classList.remove('layout-v2', 'layout-v3', 'layout-v4', 'layout-v5', 'layout-v6');
        if (v !== 'v1') b.classList.add('layout-' + v);
    } catch (e) {}
})();

// Hamburger — zwijane menu na mobilnych
(function () {
    var t = document.getElementById('appNavToggle');
    var m = document.getElementById('appNavMenu');
    if (!t || !m) return;
    t.addEventListener('click', function () {
        var open = m.classList.toggle('open');
        t.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    m.addEventListener('click', function (e) {
        if (e.target.closest('a')) { m.classList.remove('open'); t.setAttribute('aria-expanded', 'false'); }
    });
    window.addEventListener('resize', function () {
        if (window.innerWidth > 860 && m.classList.contains('open')) {
            m.classList.remove('open'); t.setAttribute('aria-expanded', 'false');
        }
    });
})();
</script>
